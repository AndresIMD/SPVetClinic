@page "/home-d"
@layout VariantCLayout
@implements IDisposable

<PageTitle>San Pablo Vet Clínic — Clínica Veterinaria en Rancagua</PageTitle>
<HeadContent>
    <meta name="description"
          content="Clínica veterinaria en Rancagua con urgencias 24/7. Especialistas certificados, laboratorio IDEXX y atención a domicilio." />
</HeadContent>

<!-- ============================================
     VARIANTE D — CAROUSEL + INFO COMPLETA
     Combina: hero carousel (C) + contenido
     detallado inline (C3), todo sobre blanco.
     ============================================ -->

<!-- ▸ HERO CAROUSEL -->
<section class="vd-hero" @onmouseenter="OnHeroEnter" @onmouseleave="OnHeroLeave">
    <div class="vd-hero__slide @(currentSlide == 0 ? "active" : "")">
        <div class="vd-hero__bg">
            <img src="@ImagePaths.Hero.ClinicFrontage"
                 alt="Fachada San Pablo Vet Clínic" onerror="this.style.display='none'" />
        </div>
        <div class="vd-hero__overlay"></div>
        <div class="vd-hero__content">
            <div class="vd-hero__tag"><span class="vd-pulse"></span> URGENCIAS 24/7 — ABIERTO AHORA</div>
            <h1 class="vd-hero__title">Veterinaria de<br /><span class="vd-accent">alto nivel</span></h1>
            <p class="vd-hero__sub">
                Especialistas certificados · Laboratorio IDEXX · Atención a domicilio en @AppConstants.Clinic.City
            </p>
            <div class="vd-hero__btns">
                <a href="contacto" class="vd-btn vd-btn--coral"><Icon Name="alarm" Size="18" /> Emergencia Ahora</a>
                <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="vd-btn vd-btn--glass"><Icon Name="calendar" Size="18" /> Reservar Hora</a>
            </div>
        </div>
    </div>
    <div class="vd-hero__slide @(currentSlide == 1 ? "active" : "")">
        <div class="vd-hero__bg">
            <img src="@ImagePaths.Services.Cirugia" alt="Cirugía y especialistas veterinarios" onerror="this.style.display='none'" />
        </div>
        <div class="vd-hero__overlay"></div>
        <div class="vd-hero__content">
            <div class="vd-hero__tag"><span class="vd-pulse"></span> EQUIPO MÉDICO ESPECIALIZADO</div>
            <h1 class="vd-hero__title">Especialistas<br /><span class="vd-accent">certificados</span></h1>
            <p class="vd-hero__sub">Neurología · Medicina Felina · Endocrinología · Cirugía avanzada</p>
            <div class="vd-hero__btns">
                <a href="especialistas" class="vd-btn vd-btn--coral"><Icon Name="brain" Size="18" /> Ver Especialistas</a>
                <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="vd-btn vd-btn--glass"><Icon Name="calendar" Size="18" /> Agendar Hora</a>
            </div>
        </div>
    </div>
    <div class="vd-hero__slide @(currentSlide == 2 ? "active" : "")">
        <div class="vd-hero__bg">
            <img src="@ImagePaths.Services.Examenes" alt="Laboratorio y exámenes veterinarios" onerror="this.style.display='none'" />
        </div>
        <div class="vd-hero__overlay"></div>
        <div class="vd-hero__content">
            <div class="vd-hero__tag"><span class="vd-pulse"></span> SERVICIOS INTEGRALES</div>
            <h1 class="vd-hero__title">Todo para el cuidado<br /><span class="vd-accent">de tu mascota</span></h1>
            <p class="vd-hero__sub">Consultas · Laboratorio IDEXX · Vacunación · Peluquería · Atención a domicilio</p>
            <div class="vd-hero__btns">
                <a href="servicios" class="vd-btn vd-btn--coral"><Icon Name="stethoscope" Size="18" /> Ver Servicios</a>
                <a href="@AppConstants.Urls.WhatsAppMobileVetLink" target="_blank" class="vd-btn vd-btn--glass"><Icon Name="van" Size="18" /> Vet a Domicilio</a>
            </div>
        </div>
    </div>

    <div class="vd-hero__dots">
        <button class="vd-hero__dot @(currentSlide == 0 ? "active" : "")" @onclick="() => GoToSlide(0)"></button>
        <button class="vd-hero__dot @(currentSlide == 1 ? "active" : "")" @onclick="() => GoToSlide(1)"></button>
        <button class="vd-hero__dot @(currentSlide == 2 ? "active" : "")" @onclick="() => GoToSlide(2)"></button>
    </div>
    <button class="vd-hero__nav vd-hero__nav--prev" @onclick="PrevSlide" aria-label="Anterior">‹</button>
    <button class="vd-hero__nav vd-hero__nav--next" @onclick="NextSlide" aria-label="Siguiente">›</button>
</section>

<!-- ▸ BARRA ACCESO RÁPIDO -->
<section class="vd-quick">
    <div class="vd-w">
        <div class="vd-quick__grid">
            <a href="contacto" class="vd-qb vd-qb--urgent">
                <Icon Name="alarm" Size="20" />
                <div><strong>Urgencias 24/7</strong><span>Atención inmediata</span></div>
            </a>
            <a href="@AppConstants.Urls.WhatsAppMobileVetLink" target="_blank" class="vd-qb">
                <Icon Name="van" Size="20" />
                <div><strong>Vet a Domicilio</strong><span>@AppConstants.Phone.MobileVetWhatsAppFormatted</span></div>
            </a>
            <a href="especialistas" class="vd-qb">
                <Icon Name="brain" Size="20" />
                <div><strong>Especialistas</strong><span>Neurología · Felina · Endocrinología</span></div>
            </a>
            <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="vd-qb">
                <Icon Name="calendar" Size="20" />
                <div><strong>Agenda Online</strong><span>Reserva tu hora fácilmente</span></div>
            </a>
        </div>
    </div>
</section>

<!-- ▸ URGENCIAS (inline — estilo C3 pero sobre blanco) -->
<section class="vd-section" id="urgencias">
    <div class="vd-w">
        <div class="vd-urgency reveal">
            <div class="vd-urgency__icon"><Icon Name="alarm" Size="28" /></div>
            <div class="vd-urgency__body">
                <h2>Urgencias Veterinarias 24/7</h2>
                <p>
                    Atención inmediata las 24 horas, los 365 días del año —incluidos festivos.
                    Si tu mascota tiene una emergencia, no esperes.
                </p>
                <div class="vd-urgency__contact">
                    <a href="@AppConstants.Urls.WhatsAppMainLink" target="_blank" class="vd-btn vd-btn--coral">
                        <Icon Name="phone" Size="16" /> @AppConstants.Phone.MainWhatsAppFormatted
                    </a>
                    <span class="vd-urgency__addr"><Icon Name="location" Size="14" /> @AppConstants.Clinic.FullAddress</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ ESPECIALISTAS (detallados inline — estilo C3 horizontal) -->
<section class="vd-section" id="especialistas">
    <div class="vd-w">
        <div class="vd-sh">
            <span class="vd-tag">Equipo Médico</span>
            <h2>Especialistas Certificados</h2>
        </div>

        <div class="vd-specs">
            <div class="vd-spec reveal stagger-1">
                <div class="vd-spec__photo">
                    <div class="vd-spec__avatar" style="display:flex"><Icon Name="brain" Size="28" /></div>
                </div>
                <div class="vd-spec__info">
                    <h3>Dr. Hernán Vargas</h3>
                    <span class="vd-spec__role">Neurología Veterinaria</span>
                    <p>Especialista en convulsiones, problemas de equilibrio, dolor de cuello y movimientos anormales. Más de 15 años de experiencia en el área.</p>
                    <span class="vd-spec__when"><Icon Name="calendar" Size="14" /> Todos los Sábados</span>
                </div>
            </div>
            <div class="vd-spec reveal stagger-2">
                <div class="vd-spec__photo">
                    <div class="vd-spec__avatar vd-spec__avatar--coral" style="display:flex"><Icon Name="cat" Size="28" /></div>
                </div>
                <div class="vd-spec__info">
                    <h3>Dra. Pilar Muñoz</h3>
                    <span class="vd-spec__role">Medicina Felina</span>
                    <p>Especialista exclusiva en gatos. Atención cuidadosa en un ambiente diseñado para felinos, reduciendo el estrés de la visita.</p>
                    <span class="vd-spec__when"><Icon Name="calendar" Size="14" /> Agenda Disponible</span>
                </div>
            </div>
            <div class="vd-spec reveal stagger-3">
                <div class="vd-spec__photo">
                    <div class="vd-spec__avatar vd-spec__avatar--purple" style="display:flex"><Icon Name="flask" Size="28" /></div>
                </div>
                <div class="vd-spec__info">
                    <h3>Endocrinología</h3>
                    <span class="vd-spec__role">Especialista Visitante</span>
                    <p>Tratamiento de problemas hormonales, diabetes, tiroides y condiciones endocrinas en pequeños animales.</p>
                    <span class="vd-spec__when"><Icon Name="calendar" Size="14" /> Consultar disponibilidad</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ SERVICIOS (cards con imagen) -->
<section class="vd-section vd-section--soft">
    <div class="vd-w">
        <div class="vd-sh">
            <span class="vd-tag">Servicios</span>
            <h2>Lo que hacemos</h2>
            <p>Atención integral con equipos de última generación y un equipo comprometido.</p>
        </div>

        <div class="vd-svc-grid">
            <div class="vd-svc reveal stagger-1">
                <div class="vd-svc__img no-img">
                    <div class="vd-svc__fb"><Icon Name="stethoscope" Size="28" /></div>
                    <span class="vd-svc__num">01</span>
                </div>
                <h3>Consulta General</h3>
                <p>Evaluaciones completas, diagnósticos precisos y planes de tratamiento personalizados.</p>
            </div>
            <div class="vd-svc reveal stagger-2">
                <div class="vd-svc__img">
                    <img src="@ImagePaths.Services.Examenes" alt="Laboratorio IDEXX"
                         onerror="this.parentElement.classList.add('no-img')" />
                    <div class="vd-svc__fb"><Icon Name="microscope" Size="28" /></div>
                    <span class="vd-svc__num">02</span>
                </div>
                <h3>Laboratorio IDEXX</h3>
                <p>Hemogramas, bioquímica, PCR y diagnóstico por imágenes con resultados rápidos.</p>
            </div>
            <div class="vd-svc reveal stagger-3">
                <div class="vd-svc__img">
                    <img src="@ImagePaths.Services.Cirugia" alt="Cirugía veterinaria"
                         onerror="this.parentElement.classList.add('no-img')" />
                    <div class="vd-svc__fb"><Icon Name="syringe" Size="28" /></div>
                    <span class="vd-svc__num">03</span>
                </div>
                <h3>Cirugía y Hospitalización</h3>
                <p>Procedimientos seguros con monitoreo constante y cuidados post-operatorios.</p>
            </div>
            <div class="vd-svc reveal stagger-4">
                <div class="vd-svc__img no-img">
                    <div class="vd-svc__fb"><Icon Name="pill" Size="28" /></div>
                    <span class="vd-svc__num">04</span>
                </div>
                <h3>Vacunación y Prevención</h3>
                <p>Programas de vacunación, desparasitación y medicina preventiva.</p>
            </div>
            <div class="vd-svc reveal stagger-5">
                <div class="vd-svc__img no-img">
                    <div class="vd-svc__fb"><Icon Name="scissors" Size="28" /></div>
                    <span class="vd-svc__num">05</span>
                </div>
                <h3>Peluquería y Estética</h3>
                <p>Baños medicados, cortes profesionales y cuidado integral de higiene.</p>
            </div>
            <div class="vd-svc reveal stagger-6">
                <div class="vd-svc__img no-img">
                    <div class="vd-svc__fb"><Icon Name="chart" Size="28" /></div>
                    <span class="vd-svc__num">06</span>
                </div>
                <h3>Imagenología</h3>
                <p>Ecografía, radiografía y electrocardiograma para diagnósticos certeros.</p>
            </div>
        </div>
    </div>
</section>

<!-- ▸ VET MÓVIL -->
<section class="vd-section">
    <div class="vd-w">
        <div class="vd-movil reveal">
            <div class="vd-movil__text">
                <span class="vd-tag">Atención a Domicilio</span>
                <h2>San Pablo<br />Vet Móvil</h2>
                <p>
                    Llevamos la atención veterinaria profesional a la puerta de tu casa.
                    Ideal para mascotas que se estresan con los viajes o tutores con movilidad reducida.
                </p>
                <ul class="vd-check-list">
                    <li><Icon Name="check" Size="16" /> Consultas veterinarias completas</li>
                    <li><Icon Name="check" Size="16" /> Vacunación y toma de muestras</li>
                    <li><Icon Name="check" Size="16" /> Control de pacientes crónicos</li>
                    <li><Icon Name="check" Size="16" /> Lunes a Domingo, 09:00 a 16:30 hrs</li>
                </ul>
                <a href="@AppConstants.Urls.WhatsAppMobileVetLink" target="_blank" class="vd-btn vd-btn--coral">
                    <Icon Name="phone" Size="18" /> Agendar Visita · @AppConstants.Phone.MobileVetWhatsAppFormatted
                </a>
            </div>
            <div class="vd-movil__img">
                <img src="@ImagePaths.Services.VetMovil" alt="Servicio veterinario a domicilio"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="vd-movil__fb">
                    <Icon Name="van" Size="52" />
                    <span>Servicio Móvil</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ UBICACIÓN + CONTACTO (inline completo — estilo C3) -->
<section class="vd-section vd-section--soft" id="contacto">
    <div class="vd-w">
        <div class="vd-contact reveal">
            <div class="vd-contact__info">
                <span class="vd-tag">Encuéntranos</span>
                <h2>Ubicación y Contacto</h2>
                <div class="vd-contact__items">
                    <div class="vd-contact__item">
                        <Icon Name="location" Size="18" />
                        <div><strong>Dirección</strong><br />@AppConstants.Clinic.FullAddress</div>
                    </div>
                    <div class="vd-contact__item">
                        <Icon Name="clock" Size="18" />
                        <div><strong>Horario</strong><br />24 horas, todos los días</div>
                    </div>
                    <div class="vd-contact__item">
                        <Icon Name="phone" Size="18" />
                        <div><strong>Teléfono</strong><br />@AppConstants.Phone.AllPhonesFormatted</div>
                    </div>
                </div>
                <div class="vd-contact__actions">
                    <a href="@AppConstants.Maps.DirectionsUrl" target="_blank" class="vd-btn vd-btn--dark">
                        <Icon Name="location" Size="18" /> Ver en Google Maps
                    </a>
                    <a href="contacto" class="vd-btn vd-btn--outline">
                        <Icon Name="phone" Size="18" /> Contacto
                    </a>
                </div>
                <div class="vd-contact__social">
                    <a href="@AppConstants.Social.InstagramUrl" target="_blank">@@spvetclinic</a>
                    <a href="@AppConstants.Social.FacebookUrl" target="_blank">Facebook</a>
                </div>
            </div>
            <div class="vd-contact__map">
                <div class="vd-contact__map-fb" style="display:flex">
                    <Icon Name="location" Size="40" />
                    <span>Rancagua, Chile</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ CONÓCENOS -->
<section class="vd-section vd-section--soft">
    <div class="vd-w">
        <div class="vd-about reveal">
            <div class="vd-about__img">
                <img src="@ImagePaths.Clinic.Fachada" alt="Fachada San Pablo Vet Clínic"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="vd-about__img-fb">
                    <Icon Name="paw" Size="48" />
                </div>
                <div class="vd-about__badge"><strong>Desde 2014</strong></div>
            </div>
            <div class="vd-about__text">
                <span class="vd-tag">Quiénes Somos</span>
                <h2>Más que una clínica</h2>
                <p>
                    En San Pablo Vet Clínic nos apasiona la medicina veterinaria. Desde 2014 hemos
                    construido un equipo multidisciplinario con especialistas en diversas áreas,
                    tecnología de diagnóstico de última generación y un compromiso genuino con cada paciente.
                </p>
                <ul class="vd-check-list">
                    <li><Icon Name="check" Size="16" /> Urgencias 24 horas, los 365 días del año</li>
                    <li><Icon Name="check" Size="16" /> Especialistas certificados en múltiples áreas</li>
                    <li><Icon Name="check" Size="16" /> Laboratorio IDEXX para diagnósticos precisos</li>
                    <li><Icon Name="check" Size="16" /> Atención veterinaria a domicilio</li>
                </ul>
                <a href="conocenos" class="vd-btn vd-btn--dark"><Icon Name="heart" Size="18" /> Conoce nuestra historia</a>
            </div>
        </div>
    </div>
</section>

<!-- ▸ EXPLORAR -->
<section class="vd-section">
    <div class="vd-w">
        <div class="vd-explore reveal">
            <a href="conocenos" class="vd-explore__chip"><Icon Name="heart" Size="18" /><span>Nuestra Historia</span></a>
            <a href="parvovirus" class="vd-explore__chip"><Icon Name="shield" Size="18" /><span>Info: Parvovirus</span></a>
            <a href="servicios" class="vd-explore__chip"><Icon Name="stethoscope" Size="18" /><span>Todos los Servicios</span></a>
            <a href="hospitalizacion" class="vd-explore__chip"><Icon Name="clinic" Size="18" /><span>Hospitalización</span></a>
        </div>
    </div>
</section>

<!-- ▸ CTA FINAL -->
<section class="vd-cta">
    <div class="vd-cta__inner reveal">
        <span class="vd-tag vd-tag--light">Disponible 24/7</span>
        <h2>¿Tu mascota necesita<br />atención <em>ahora</em>?</h2>
        <div class="vd-cta__btns">
            <a href="contacto" class="vd-btn vd-btn--coral vd-btn--lg"><Icon Name="alarm" Size="20" /> Urgencias 24/7</a>
            <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="vd-btn vd-btn--glass vd-btn--lg"><Icon Name="calendar" Size="20" /> Agendar Consulta</a>
        </div>
        <div class="vd-cta__addr"><Icon Name="location" Size="14" /> @AppConstants.Clinic.FullAddress</div>
    </div>
</section>

<div class="vd-back">
    <NavLink href="variantes" class="vd-back__link">← Volver a las variantes</NavLink>
</div>

<style>
    /* ===== VARIANTE D — CAROUSEL + INFO COMPLETA ===== */
    .vd-w { max-width: 1100px; margin: 0 auto; }
    .vd-tag { display: inline-block; font-size: 0.7rem; font-weight: 700; color: var(--accent-coral); text-transform: uppercase; letter-spacing: 0.15em; }
    .vd-tag--light { color: rgba(255,255,255,0.6); }
    .vd-accent { background: linear-gradient(135deg, var(--primary-teal), #87d4e8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .vd-sh { margin-bottom: 2.5rem; }
    .vd-sh h2 { font-size: var(--font-size-h2); font-weight: 800; color: var(--text-dark); margin: 0.25rem 0 0; letter-spacing: -0.02em; }
    .vd-sh p { color: var(--text-gray); max-width: 520px; margin: 0.5rem 0 0; line-height: 1.7; }

    .vd-check-list { list-style: none; padding: 0; margin: 0 0 1.75rem; display: flex; flex-direction: column; gap: 0.5rem; }
    .vd-check-list li { display: flex; align-items: center; gap: 0.5rem; font-size: var(--font-size-sm); color: var(--text-dark); font-weight: 500; }

    /* BUTTONS */
    .vd-btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.875rem 1.75rem; border-radius: var(--border-radius);
        font-weight: 700; font-size: var(--font-size-base); text-decoration: none;
        transition: var(--transition); border: 2px solid transparent;
        text-transform: uppercase; letter-spacing: 0.04em;
    }
    .vd-btn--lg { padding: 1rem 2.25rem; font-size: 1.0625rem; }
    .vd-btn--coral { background: var(--accent-coral); color: white; border-color: var(--accent-coral); }
    .vd-btn--coral:hover { background: var(--accent-coral-dark); border-color: var(--accent-coral-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(187,84,95,0.4); }
    .vd-btn--glass { background: rgba(255,255,255,0.08); color: white; border-color: rgba(255,255,255,0.2); backdrop-filter: blur(8px); }
    .vd-btn--glass:hover { background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); }
    .vd-btn--dark { background: var(--text-dark); color: white; border-color: var(--text-dark); }
    .vd-btn--dark:hover { background: #000; transform: translateY(-2px); box-shadow: var(--shadow-medium); }
    .vd-btn--outline { background: transparent; color: var(--text-dark); border-color: #d4d8dd; }
    .vd-btn--outline:hover { border-color: var(--primary-teal); color: var(--primary-teal); }

    /* HERO CAROUSEL */
    .vd-hero {
        min-height: var(--hero-height, 100vh);
        position: relative; overflow: hidden; background: #0d0d0d;
    }
    .vd-hero__slide {
        position: absolute; inset: 0;
        display: flex; align-items: center; justify-content: center; text-align: center;
        opacity: 0; visibility: hidden; transition: opacity 0.8s ease, visibility 0.8s ease;
    }
    .vd-hero__slide.active { opacity: 1; visibility: visible; }
    .vd-hero__bg { position: absolute; inset: 0; }
    .vd-hero__bg img { width: 100%; height: 100%; object-fit: cover; opacity: 0.3; filter: grayscale(20%); }
    .vd-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(13,13,13,0.4) 0%, rgba(13,13,13,0.85) 100%); }
    .vd-hero__content { position: relative; z-index: 1; max-width: 800px; padding: 4rem 2rem; }
    .vd-hero__tag { display: inline-flex; align-items: center; gap: 8px; color: var(--accent-coral); font-size: var(--font-size-sm); font-weight: 700; letter-spacing: 0.15em; margin-bottom: 1.5rem; }
    .vd-pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-coral); animation: vd-pulse 1.5s ease-in-out infinite; }
    @@keyframes vd-pulse { 0%,100%{box-shadow:0 0 0 0 rgba(187,84,95,0.5)} 50%{box-shadow:0 0 0 8px rgba(187,84,95,0)} }
    .vd-hero__title { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; color: white; line-height: 1.05; margin: 0 0 1rem; letter-spacing: -0.04em; }
    .vd-hero__sub { font-size: 1.0625rem; color: rgba(255,255,255,0.6); margin: 0 0 2.5rem; letter-spacing: 0.02em; line-height: 1.6; }
    .vd-hero__btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    .vd-hero__dots {
        position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
        display: flex; gap: 0.75rem; z-index: 10;
    }
    .vd-hero__dot {
        width: 10px; height: 10px; border-radius: 50%;
        background: rgba(255,255,255,0.3); border: none; padding: 0;
        cursor: pointer; transition: all 0.3s ease;
    }
    .vd-hero__dot.active { background: white; width: 28px; border-radius: 5px; }
    .vd-hero__dot:hover { background: rgba(255,255,255,0.6); }

    .vd-hero__nav {
        position: absolute; top: 50%; transform: translateY(-50%);
        width: 48px; height: 48px; border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.15); background: rgba(0,0,0,0.25);
