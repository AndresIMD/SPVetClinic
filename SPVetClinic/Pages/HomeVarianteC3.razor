@page "/home-c3"
@layout VariantCLayout

<PageTitle>San Pablo Vet Clínic — Clínica Veterinaria en Rancagua</PageTitle>
<HeadContent>
    <meta name="description" content="Clínica veterinaria con urgencias 24/7, especialistas certificados y atención a domicilio en Rancagua." />
</HeadContent>

<!-- ============================================
     C-3: ONE-PAGE FLOW
     Todo accesible sin salir. Scroll fluido,
     secciones alternas, información completa
     inline. Mínima navegación externa.
     ============================================ -->

<!-- ▸ HERO FULL -->
<section class="c3-hero">
    <div class="c3-hero__bg">
        <img src="@ImagePaths.Hero.Frontage"
             alt="San Pablo Vet Clínic en Rancagua" class="c3-hero__bg-img"
             onerror="this.style.display='none'" />
        <div class="c3-hero__overlay"></div>
    </div>
    <div class="c3-hero__content">
        <div class="c3-hero__urgency">
            <span class="c3-pulse"></span> URGENCIAS 24/7 — ABIERTO AHORA
        </div>
        <h1>Veterinaria de<br /><span class="c3-accent">alto nivel</span></h1>
        <p>Especialistas certificados · Laboratorio IDEXX · Atención a domicilio en @AppConstants.Clinic.City</p>
        <div class="c3-hero__btns">
            <a href="contacto" class="c3-btn c3-btn--coral">
                <Icon Name="alarm" Size="18" /> Emergencia Ahora
            </a>
            <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="c3-btn c3-btn--glass">
                <Icon Name="calendar" Size="18" /> Reservar Hora
            </a>
        </div>
    </div>
</section>

<!-- ▸ URGENCIAS (inline completo) -->
<section class="c3-dark" id="urgencias">
    <div class="c3-w">
        <div class="c3-urgency reveal">
            <div class="c3-urgency__icon"><Icon Name="alarm" Size="28" /></div>
            <div class="c3-urgency__body">
                <h2>Urgencias Veterinarias 24/7</h2>
                <p>
                    Atención inmediata las 24 horas, los 365 días del año —incluidos festivos.
                    Si tu mascota tiene una emergencia, no esperes.
                </p>
                <div class="c3-urgency__contact">
                    <a href="@AppConstants.Urls.WhatsAppMainLink" target="_blank" class="c3-btn c3-btn--coral">
                        <Icon Name="phone" Size="16" /> @AppConstants.Phone.MainWhatsAppFormatted
                    </a>
                    <span class="c3-urgency__addr"><Icon Name="location" Size="14" /> @AppConstants.Clinic.FullAddress</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ ESPECIALISTAS (inline con detalle) -->
<section class="c3-light" id="especialistas">
    <div class="c3-w">
        <div class="c3-sh">
            <span class="c3-tag">Equipo Médico</span>
            <h2>Especialistas Certificados</h2>
        </div>

        <div class="c3-spec-grid">
            <div class="c3-spec reveal stagger-1">
                <div class="c3-spec__photo">
                    <div class="c3-spec__avatar" style="display:flex"><Icon Name="brain" Size="28" /></div>
                </div>
                <div class="c3-spec__info">
                    <h3>Dr. Hernán Vargas</h3>
                    <span class="c3-spec__role">Neurología Veterinaria</span>
                    <p>Especialista en convulsiones, problemas de equilibrio, dolor de cuello y movimientos anormales. Más de 15 años de experiencia en el área.</p>
                    <span class="c3-spec__when"><Icon Name="calendar" Size="14" /> Todos los Sábados</span>
                </div>
            </div>
            <div class="c3-spec reveal stagger-2">
                <div class="c3-spec__photo">
                    <div class="c3-spec__avatar c3-spec__avatar--coral" style="display:flex"><Icon Name="cat" Size="28" /></div>
                </div>
                <div class="c3-spec__info">
                    <h3>Dra. Pilar Muñoz</h3>
                    <span class="c3-spec__role">Medicina Felina</span>
                    <p>Especialista exclusiva en gatos. Atención cuidadosa en un ambiente diseñado para felinos, reduciendo el estrés de la visita.</p>
                    <span class="c3-spec__when"><Icon Name="calendar" Size="14" /> Agenda Disponible</span>
                </div>
            </div>
            <div class="c3-spec reveal stagger-3">
                <div class="c3-spec__photo">
                    <div class="c3-spec__avatar c3-spec__avatar--purple" style="display:flex"><Icon Name="flask" Size="28" /></div>
                </div>
                <div class="c3-spec__info">
                    <h3>Endocrinología</h3>
                    <span class="c3-spec__role">Especialista Visitante</span>
                    <p>Tratamiento de problemas hormonales, diabetes, tiroides y condiciones endocrinas en pequeños animales.</p>
                    <span class="c3-spec__when"><Icon Name="calendar" Size="14" /> Consultar disponibilidad</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ VET MÓVIL (inline completo) -->
<section class="c3-dark" id="vetmovil">
    <div class="c3-w">
        <div class="c3-movil reveal">
            <div class="c3-movil__text">
                <span class="c3-tag">Atención a Domicilio</span>
                <h2>San Pablo Vet Móvil</h2>
                <p>
                    Atención veterinaria profesional en la puerta de tu casa.
                    Ideal para mascotas que se estresan con los viajes o tutores con movilidad reducida.
                </p>
                <ul class="c3-list">
                    <li><Icon Name="check" Size="16" /> Consultas veterinarias completas</li>
                    <li><Icon Name="check" Size="16" /> Vacunación y toma de muestras</li>
                    <li><Icon Name="check" Size="16" /> Control de pacientes crónicos</li>
                    <li><Icon Name="check" Size="16" /> Lunes a Domingo, 09:00 a 16:30 hrs</li>
                </ul>
                <a href="@AppConstants.Urls.WhatsAppMobileVetLink" target="_blank" class="c3-btn c3-btn--coral">
                    <Icon Name="phone" Size="16" /> @AppConstants.Phone.MobileVetWhatsAppFormatted
                </a>
            </div>
            <div class="c3-movil__img">
                <img src="@ImagePaths.Services.VetMovil" alt="Vet Móvil"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="c3-movil__fallback"><Icon Name="van" Size="48" /><span>Servicio Móvil</span></div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ SERVICIOS (todos inline) -->
<section class="c3-light" id="servicios">
    <div class="c3-w">
        <div class="c3-sh">
            <span class="c3-tag">Servicios</span>
            <h2>Todo lo que necesitas</h2>
        </div>

        <div class="c3-services">
            <div class="c3-svc reveal stagger-1">
                <div class="c3-svc__img no-img">
                    <div class="c3-svc__fb"><Icon Name="stethoscope" Size="24" /></div>
                </div>
                <h3>Consulta General</h3>
                <p>Evaluaciones completas y planes de tratamiento personalizados.</p>
            </div>
            <div class="c3-svc reveal stagger-2">
                <div class="c3-svc__img">
                    <img src="@ImagePaths.Services.Examenes" alt="Laboratorio"
                         onerror="this.parentElement.classList.add('no-img')" />
                    <div class="c3-svc__fb"><Icon Name="microscope" Size="24" /></div>
                </div>
                <h3>Laboratorio IDEXX</h3>
                <p>Hemogramas, bioquímica, PCR y resultados rápidos.</p>
            </div>
            <div class="c3-svc reveal stagger-3">
                <div class="c3-svc__img">
                    <img src="@ImagePaths.Services.Cirugia" alt="Cirugía"
                         onerror="this.parentElement.classList.add('no-img')" />
                    <div class="c3-svc__fb"><Icon Name="syringe" Size="24" /></div>
                </div>
                <h3>Cirugía</h3>
                <p>Procedimientos seguros con monitoreo constante.</p>
            </div>
            <div class="c3-svc reveal stagger-4">
                <div class="c3-svc__img no-img">
                    <div class="c3-svc__fb"><Icon Name="pill" Size="24" /></div>
                </div>
                <h3>Vacunación</h3>
                <p>Programas completos para cada etapa de vida.</p>
            </div>
            <div class="c3-svc reveal stagger-5">
                <div class="c3-svc__img no-img">
                    <div class="c3-svc__fb"><Icon Name="scissors" Size="24" /></div>
                </div>
                <h3>Peluquería</h3>
                <p>Baños medicados y cortes profesionales.</p>
            </div>
            <div class="c3-svc reveal stagger-6">
                <div class="c3-svc__img no-img">
                    <div class="c3-svc__fb"><Icon Name="chart" Size="24" /></div>
                </div>
                <h3>Imagenología</h3>
                <p>Ecografía, radiografía y electrocardiograma.</p>
            </div>
        </div>
    </div>
</section>

<!-- ▸ INFO RÁPIDA (contacto + ubicación inline) -->
<section class="c3-dark" id="contacto">
    <div class="c3-w">
        <div class="c3-info reveal">
            <div class="c3-info__col">
                <span class="c3-tag">Encuéntranos</span>
                <h2>Ubicación y Contacto</h2>
                <div class="c3-info__items">
                    <div class="c3-info__item">
                        <Icon Name="location" Size="18" />
                        <div><strong>Dirección</strong><br />@AppConstants.Clinic.FullAddress</div>
                    </div>
                    <div class="c3-info__item">
                        <Icon Name="clock" Size="18" />
                        <div><strong>Horario</strong><br />24 horas, todos los días</div>
                    </div>
                    <div class="c3-info__item">
                        <Icon Name="phone" Size="18" />
                        <div><strong>Teléfono</strong><br />@AppConstants.Phone.AllPhonesFormatted</div>
                    </div>
                </div>
                <div class="c3-info__social">
                    <a href="@AppConstants.Social.InstagramUrl" target="_blank">@@spvetclinic</a>
                    <a href="@AppConstants.Social.FacebookUrl" target="_blank">Facebook</a>
                </div>
            </div>
            <div class="c3-info__map">
                <div class="c3-info__map-fb" style="display:flex">
                    <Icon Name="location" Size="36" />
                    <span>Rancagua, Chile</span>
                    <a href="@AppConstants.Maps.DirectionsUrl" target="_blank" class="c3-btn c3-btn--glass">
                        Ver en Google Maps
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ EXPLORAR (contenido secundario) -->
<section class="c3-light">
    <div class="c3-w">
        <div class="c3-explore reveal">
            <a href="conocenos" class="c3-explore__item">
                <Icon Name="heart" Size="18" />
                <span>Nuestra Historia</span>
            </a>
            <a href="parvovirus" class="c3-explore__item">
                <Icon Name="shield" Size="18" />
                <span>Info: Parvovirus</span>
            </a>
            <a href="servicios" class="c3-explore__item">
                <Icon Name="stethoscope" Size="18" />
                <span>Todos los Servicios</span>
            </a>
            <a href="hospitalizacion" class="c3-explore__item">
                <Icon Name="clinic" Size="18" />
                <span>Hospitalización</span>
            </a>
        </div>
    </div>
</section>

<!-- ▸ CTA FINAL -->
<section class="c3-cta">
    <div class="c3-cta__inner reveal">
        <span class="c3-tag">Disponible 24/7</span>
        <h2>¿Tu mascota necesita atención?</h2>
        <div class="c3-cta__btns">
            <a href="contacto" class="c3-btn c3-btn--coral c3-btn--lg">
                <Icon Name="alarm" Size="20" /> Urgencias 24/7
            </a>
            <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="c3-btn c3-btn--glass c3-btn--lg">
                <Icon Name="calendar" Size="20" /> Agendar Consulta
            </a>
        </div>
    </div>
</section>

<div class="c3-back">
    <NavLink href="variantes" class="c3-back__link">← Volver a las variantes</NavLink>
</div>

<style>
    /* ===== C-3 ONE-PAGE ===== */
    .c3-w { max-width: 1100px; margin: 0 auto; }
    .c3-tag { display: inline-block; font-size: 0.7rem; font-weight: 700; color: var(--accent-coral); text-transform: uppercase; letter-spacing: 0.15em; }
    .c3-accent { background: linear-gradient(135deg, var(--primary-teal), #87d4e8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .c3-sh { margin-bottom: 2rem; }
    .c3-sh h2 { font-size: var(--font-size-h2); font-weight: 800; color: var(--text-dark); margin: 0.25rem 0 0; letter-spacing: -0.02em; }

    .c3-dark { padding: 4rem 2rem; background: #111; }
    .c3-light { padding: 4rem 2rem; background: white; }

    .c3-list { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.4rem; }
    .c3-list li { display: flex; align-items: center; gap: 0.5rem; font-size: var(--font-size-sm); color: rgba(255,255,255,0.6); }

    /* BUTTONS */
    .c3-btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.8rem 1.5rem; border-radius: var(--border-radius);
        font-weight: 700; font-size: var(--font-size-sm); text-decoration: none;
        transition: var(--transition); border: 2px solid transparent;
        text-transform: uppercase; letter-spacing: 0.04em;
    }
    .c3-btn--lg { padding: 1rem 2rem; font-size: var(--font-size-base); }
    .c3-btn--coral { background: var(--accent-coral); color: white; border-color: var(--accent-coral); }
    .c3-btn--coral:hover { background: var(--accent-coral-dark); border-color: var(--accent-coral-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(187,84,95,0.4); }
    .c3-btn--glass { background: rgba(255,255,255,0.08); color: white; border-color: rgba(255,255,255,0.2); backdrop-filter: blur(8px); }
    .c3-btn--glass:hover { background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); }

    /* HERO */
    .c3-hero {
        min-height: var(--hero-height, 100vh);
        display: flex; align-items: center; justify-content: center;
        text-align: center; padding: 4rem 2rem; position: relative; overflow: hidden; background: #0d0d0d;
    }
    .c3-hero__bg { position: absolute; inset: 0; }
    .c3-hero__bg-img { width: 100%; height: 100%; object-fit: cover; opacity: 0.25; filter: grayscale(30%); }
    .c3-hero__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(13,13,13,0.55), rgba(13,13,13,0.88)); }
    .c3-hero__content { position: relative; z-index: 1; max-width: 800px; }
    .c3-hero__urgency { display: inline-flex; align-items: center; gap: 8px; color: var(--accent-coral); font-size: var(--font-size-sm); font-weight: 700; letter-spacing: 0.15em; margin-bottom: 1.5rem; }
    .c3-pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-coral); animation: c3pulse 1.5s ease-in-out infinite; }
    @@keyframes c3pulse { 0%,100%{box-shadow:0 0 0 0 rgba(187,84,95,0.5)} 50%{box-shadow:0 0 0 8px rgba(187,84,95,0)} }
    .c3-hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; color: white; line-height: 1.05; margin: 0 0 1rem; letter-spacing: -0.04em; }
    .c3-hero p { color: rgba(255,255,255,0.55); font-size: 1.0625rem; margin: 0 0 2.5rem; line-height: 1.6; }
    .c3-hero__btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    /* URGENCY SECTION */
    .c3-urgency {
        display: flex; gap: 2rem; align-items: flex-start;
        background: rgba(187,84,95,0.08); border: 1px solid rgba(187,84,95,0.15);
        border-radius: 16px; padding: 2.5rem;
    }
    .c3-urgency__icon {
        width: 56px; height: 56px; border-radius: 14px; flex-shrink: 0;
        background: var(--accent-coral); color: white;
        display: flex; align-items: center; justify-content: center;
    }
    .c3-urgency__body h2 { font-size: 1.5rem; font-weight: 800; color: white; margin: 0 0 0.5rem; }
    .c3-urgency__body > p { color: rgba(255,255,255,0.6); line-height: 1.7; margin: 0 0 1.25rem; font-size: var(--font-size-base); }
    .c3-urgency__contact { display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
    .c3-urgency__addr { font-size: var(--font-size-sm); color: rgba(255,255,255,0.4); display: inline-flex; align-items: center; gap: 0.35rem; }

    /* SPECIALISTS */
    .c3-spec-grid { display: flex; flex-direction: column; gap: 1rem; }

    .c3-spec {
        display: flex; gap: 1.5rem; align-items: flex-start;
        background: #fafbfc; border: 1px solid #eef1f5;
        border-radius: 14px; padding: 1.5rem; transition: var(--transition);
    }
    .c3-spec:hover { box-shadow: var(--shadow-soft); border-color: var(--primary-teal); }

    .c3-spec__photo { width: 80px; height: 80px; border-radius: 12px; overflow: hidden; flex-shrink: 0; }
    .c3-spec__photo img { width: 100%; height: 100%; object-fit: cover; }
    .c3-spec__avatar { width: 80px; height: 80px; border-radius: 12px; background: linear-gradient(135deg, var(--primary-teal), var(--primary-teal-dark)); display: none; align-items: center; justify-content: center; color: white; }
    .c3-spec__avatar--coral { background: linear-gradient(135deg, var(--accent-coral), var(--accent-coral-dark)); }
    .c3-spec__avatar--purple { background: linear-gradient(135deg, #8e44ad, #6c3483); }
    .c3-spec__info h3 { font-size: 1rem; font-weight: 700; color: var(--text-dark); margin: 0 0 0.15rem; }
    .c3-spec__role { font-size: var(--font-size-sm); color: var(--accent-coral); font-weight: 600; }
    .c3-spec p { font-size: var(--font-size-sm); color: var(--text-gray); line-height: 1.6; margin: 0.4rem 0; }
    .c3-spec__when { font-size: var(--font-size-sm); color: var(--text-gray); display: inline-flex; align-items: center; gap: 4px; }

    /* VET MÓVIL */
    .c3-movil { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.06); background: #1a1a1a; }
    .c3-movil__text { padding: 2.5rem; }
    .c3-movil__text h2 { font-size: 1.75rem; font-weight: 800; color: white; margin: 0.5rem 0 0.75rem; letter-spacing: -0.02em; }
    .c3-movil__text > p { color: rgba(255,255,255,0.6); line-height: 1.7; margin: 0 0 1.25rem; }
    .c3-movil__img { position: relative; overflow: hidden; min-height: 280px; background: rgba(98,171,191,0.08); }
    .c3-movil__img img { width: 100%; height: 100%; object-fit: cover; }
    .c3-movil__fallback { display: none; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; height: 100%; color: var(--primary-teal); font-weight: 700; }

    /* SERVICES */
    .c3-services { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
    .c3-svc { background: #fafbfc; border: 1px solid #eef1f5; border-radius: 14px; overflow: hidden; transition: var(--transition); }
    .c3-svc:hover { transform: translateY(-4px); box-shadow: var(--shadow-soft); border-color: var(--primary-teal); }
    .c3-svc__img { height: 120px; overflow: hidden; position: relative; background: var(--primary-teal-light); }
    .c3-svc__img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
    .c3-svc:hover .c3-svc__img img { transform: scale(1.06); }
    .c3-svc__fb { position: absolute; inset: 0; display: none; align-items: center; justify-content: center; color: var(--primary-teal); }
    .c3-svc__img.no-img img { display: none; }
    .c3-svc__img.no-img .c3-svc__fb { display: flex; }
    .c3-svc h3 { font-size: 0.9375rem; font-weight: 700; color: var(--text-dark); margin: 0.875rem 1rem 0.25rem; }
    .c3-svc p { font-size: var(--font-size-sm); color: var(--text-gray); line-height: 1.5; margin: 0 1rem 1rem; }

    /* INFO / CONTACTO */
    .c3-info { display: grid; grid-template-columns: 1fr 1fr; gap: 0; border-radius: 16px; overflow: hidden; border: 1px solid rgba(255,255,255,0.06); background: #1a1a1a; }
    .c3-info__col { padding: 2.5rem; }
    .c3-info__col h2 { font-size: 1.5rem; font-weight: 800; color: white; margin: 0.25rem 0 1.25rem; }
    .c3-info__items { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.5rem; }
    .c3-info__item { display: flex; gap: 0.75rem; color: rgba(255,255,255,0.6); font-size: var(--font-size-sm); line-height: 1.5; }
    .c3-info__item strong { color: white; display: block; }
    .c3-info__social { display: flex; gap: 1rem; }
    .c3-info__social a { color: var(--primary-teal); text-decoration: none; font-size: var(--font-size-sm); font-weight: 600; }
    .c3-info__social a:hover { text-decoration: underline; }

    .c3-info__map { position: relative; min-height: 280px; overflow: hidden; background: rgba(98,171,191,0.05); }
    .c3-info__map img { width: 100%; height: 100%; object-fit: cover; }
    .c3-info__map-fb { display: none; flex-direction: column; align-items: center; justify-content: center; gap: 0.75rem; height: 100%; color: rgba(255,255,255,0.4); }
    .c3-info__map-fb span { font-weight: 600; font-size: var(--font-size-sm); }

    /* EXPLORE */
    .c3-explore { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
    .c3-explore__item {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.7rem 1.25rem; background: #fafbfc;
        border: 1px solid #eef1f5; border-radius: 50px;
        color: var(--text-gray); text-decoration: none;
        font-size: var(--font-size-sm); font-weight: 500;
        transition: var(--transition);
    }
    .c3-explore__item:hover { border-color: var(--primary-teal); color: var(--primary-teal); background: var(--primary-teal-light); }

    /* CTA */
    .c3-cta { padding: 5rem 2rem; background: #0d0d0d; text-align: center; }
    .c3-cta__inner { max-width: 600px; margin: 0 auto; }
    .c3-cta h2 { font-size: clamp(1.75rem, 3.5vw, 2.5rem); color: white; margin: 0.75rem 0 2rem; font-weight: 800; letter-spacing: -0.03em; }
    .c3-cta__btns { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    .c3-back { text-align: center; padding: 1.5rem; background: #111; }
