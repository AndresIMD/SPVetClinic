@page "/home-c"
@layout VariantCLayout
@implements IDisposable

<PageTitle>San Pablo Vet Clínic — Clínica Veterinaria en Rancagua</PageTitle>
<HeadContent>
    <meta name="description"
          content="Clínica veterinaria en Rancagua con urgencias 24/7. Especialistas certificados, laboratorio IDEXX y atención a domicilio." />
</HeadContent>

<!-- ============================================
     VARIANTE C — MODERNO Y BOLD (v3)
     Hero oscuro full-screen, tipografía grande,
     alto contraste, imágenes reales, urgencias.
     ============================================ -->

<!-- ▸ HERO CAROUSEL -->
<section class="vc-hero-carousel" @onmouseenter="OnHeroEnter" @onmouseleave="OnHeroLeave">
    <!-- Slide 1: Principal -->
    <div class="vc-hc__slide @(currentSlide == 0 ? "active" : "")">
        <div class="vc-hc__bg">
            <img src="@ImagePaths.Hero.Frontage"
                 alt="Fachada San Pablo Vet Clínic" onerror="this.style.display='none'" />
        </div>
        <div class="vc-hc__overlay"></div>
        <div class="vc-hc__content">
            <div class="vc-hc__tag"><span class="vc-pulse"></span> URGENCIAS 24/7 — ABIERTO AHORA</div>
            <h1 class="vc-hc__title">Veterinaria de<br /><span class="vc-accent">alto nivel</span></h1>
            <p class="vc-hc__sub">
                Especialistas certificados · Laboratorio IDEXX · Atención a domicilio en @AppConstants.Clinic.City
            </p>
            <div class="vc-hc__btns">
                <a href="contacto" class="vc-btn vc-btn--coral"><Icon Name="alarm" Size="18" /> Emergencia Ahora</a>
                <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="vc-btn vc-btn--glass"><Icon Name="calendar" Size="18" /> Reservar Hora</a>
            </div>
        </div>
    </div>

    <!-- Slide 2: Especialistas -->
    <div class="vc-hc__slide @(currentSlide == 1 ? "active" : "")">
        <div class="vc-hc__bg">
            <img src="@ImagePaths.Services.Cirugia" alt="Cirugía y especialistas veterinarios" onerror="this.style.display='none'" />
        </div>
        <div class="vc-hc__overlay"></div>
        <div class="vc-hc__content">
            <div class="vc-hc__tag"><span class="vc-pulse"></span> EQUIPO MÉDICO ESPECIALIZADO</div>
            <h1 class="vc-hc__title">Especialistas<br /><span class="vc-accent">certificados</span></h1>
            <p class="vc-hc__sub">Neurología · Medicina Felina · Endocrinología · Cirugía avanzada</p>
            <div class="vc-hc__btns">
                <a href="especialistas" class="vc-btn vc-btn--coral"><Icon Name="brain" Size="18" /> Ver Especialistas</a>
                <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="vc-btn vc-btn--glass"><Icon Name="calendar" Size="18" /> Agendar Hora</a>
            </div>
        </div>
    </div>

    <!-- Slide 3: Servicios -->
    <div class="vc-hc__slide @(currentSlide == 2 ? "active" : "")">
        <div class="vc-hc__bg">
            <img src="@ImagePaths.Services.Examenes" alt="Laboratorio y exámenes veterinarios" onerror="this.style.display='none'" />
        </div>
        <div class="vc-hc__overlay"></div>
        <div class="vc-hc__content">
            <div class="vc-hc__tag"><span class="vc-pulse"></span> SERVICIOS INTEGRALES</div>
            <h1 class="vc-hc__title">Todo para el cuidado<br /><span class="vc-accent">de tu mascota</span></h1>
            <p class="vc-hc__sub">Consultas · Laboratorio IDEXX · Vacunación · Peluquería · Atención a domicilio</p>
            <div class="vc-hc__btns">
                <a href="servicios" class="vc-btn vc-btn--coral"><Icon Name="stethoscope" Size="18" /> Ver Servicios</a>
                <a href="@AppConstants.Urls.WhatsAppMobileVetLink" target="_blank" class="vc-btn vc-btn--glass"><Icon Name="van" Size="18" /> Vet a Domicilio</a>
            </div>
        </div>
    </div>

    <!-- Indicadores -->
    <div class="vc-hc__dots">
        <button class="vc-hc__dot @(currentSlide == 0 ? "active" : "")" @onclick="() => GoToSlide(0)"></button>
        <button class="vc-hc__dot @(currentSlide == 1 ? "active" : "")" @onclick="() => GoToSlide(1)"></button>
        <button class="vc-hc__dot @(currentSlide == 2 ? "active" : "")" @onclick="() => GoToSlide(2)"></button>
    </div>

    <!-- Navegación -->
    <button class="vc-hc__nav vc-hc__nav--prev" @onclick="PrevSlide" aria-label="Anterior">‹</button>
    <button class="vc-hc__nav vc-hc__nav--next" @onclick="NextSlide" aria-label="Siguiente">›</button>
</section>

<!-- ▸ BARRA DE ACCESO RÁPIDO -->
<section class="vc-quick-bar">
    <div class="vc-w">
        <div class="vc-quick-bar__grid">
            <a href="contacto" class="vc-qb vc-qb--urgent">
                <Icon Name="alarm" Size="20" />
                <div>
                    <strong>Urgencias 24/7</strong>
                    <span>Atención inmediata</span>
                </div>
            </a>
            <a href="@AppConstants.Urls.WhatsAppMobileVetLink" target="_blank" class="vc-qb">
                <Icon Name="van" Size="20" />
                <div>
                    <strong>Vet a Domicilio</strong>
                    <span>@AppConstants.Phone.MobileVetWhatsAppFormatted</span>
                </div>
            </a>
            <a href="especialistas" class="vc-qb">
                <Icon Name="brain" Size="20" />
                <div>
                    <strong>Especialistas</strong>
                    <span>Neurología · Felina · Endocrinología</span>
                </div>
            </a>
            <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="vc-qb">
                <Icon Name="calendar" Size="20" />
                <div>
                    <strong>Agenda Online</strong>
                    <span>Reserva tu hora fácilmente</span>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- ▸ SERVICIOS (cards con imagen) -->
<section class="vc-section vc-section--soft">
    <div class="vc-w">
        <div class="vc-section-header">
            <span class="vc-tag">Servicios</span>
            <h2>Lo que hacemos</h2>
            <p>Atención integral con equipos de última generación y un equipo comprometido.</p>
        </div>

        <div class="vc-svc-grid">
            <div class="vc-svc-card reveal stagger-1">
                <div class="vc-svc-card__img no-img">
                    <div class="vc-svc-card__fallback"><Icon Name="stethoscope" Size="28" /></div>
                    <span class="vc-svc-card__num">01</span>
                </div>
                <h3>Consulta General</h3>
                <p>Evaluaciones completas, diagnósticos precisos y planes de tratamiento personalizados.</p>
            </div>
            <div class="vc-svc-card reveal stagger-2">
                <div class="vc-svc-card__img">
                    <img src="@ImagePaths.Services.Examenes" alt="Laboratorio IDEXX"
                         onerror="this.parentElement.classList.add('no-img')" />
                    <div class="vc-svc-card__fallback"><Icon Name="microscope" Size="28" /></div>
                    <span class="vc-svc-card__num">02</span>
                </div>
                <h3>Laboratorio IDEXX</h3>
                <p>Hemogramas, bioquímica, PCR y diagnóstico por imágenes con resultados rápidos.</p>
            </div>
            <div class="vc-svc-card reveal stagger-3">
                <div class="vc-svc-card__img">
                    <img src="@ImagePaths.Services.Cirugia" alt="Cirugía veterinaria"
                         onerror="this.parentElement.classList.add('no-img')" />
                    <div class="vc-svc-card__fallback"><Icon Name="syringe" Size="28" /></div>
                    <span class="vc-svc-card__num">03</span>
                </div>
                <h3>Cirugía y Hospitalización</h3>
                <p>Procedimientos seguros con monitoreo constante y cuidados post-operatorios.</p>
            </div>
            <div class="vc-svc-card reveal stagger-4">
                <div class="vc-svc-card__img no-img">
                    <div class="vc-svc-card__fallback"><Icon Name="pill" Size="28" /></div>
                    <span class="vc-svc-card__num">04</span>
                </div>
                <h3>Vacunación y Prevención</h3>
                <p>Programas de vacunación, desparasitación y medicina preventiva.</p>
            </div>
            <div class="vc-svc-card reveal stagger-5">
                <div class="vc-svc-card__img no-img">
                    <div class="vc-svc-card__fallback"><Icon Name="scissors" Size="28" /></div>
                    <span class="vc-svc-card__num">05</span>
                </div>
                <h3>Peluquería y Estética</h3>
                <p>Baños medicados, cortes profesionales y cuidado integral de higiene.</p>
            </div>
            <div class="vc-svc-card reveal stagger-6">
                <div class="vc-svc-card__img no-img">
                    <div class="vc-svc-card__fallback"><Icon Name="chart" Size="28" /></div>
                    <span class="vc-svc-card__num">06</span>
                </div>
                <h3>Imagenología</h3>
                <p>Ecografía, radiografía y electrocardiograma para diagnósticos certeros.</p>
            </div>
        </div>
    </div>
</section>

<!-- ▸ ESPECIALISTAS -->
<section class="vc-section">
    <div class="vc-w">
        <div class="vc-section-header">
            <span class="vc-tag">Equipo Médico</span>
            <h2>Especialistas certificados</h2>
        </div>

        <div class="vc-specs">
            <div class="vc-spec-card reveal stagger-1">
                <div class="vc-spec-card__photo">
                    <div class="vc-spec-card__avatar" style="display:flex"><Icon Name="brain" Size="28" /></div>
                </div>
                <div class="vc-spec-card__body">
                    <h3>Dr. Hernán Vargas</h3>
                    <span class="vc-spec-card__role">Neurología Veterinaria</span>
                    <p>Convulsiones, problemas de equilibrio, dolor de cuello y movimientos anormales.</p>
                    <div class="vc-spec-card__meta"><Icon Name="calendar" Size="14" /> Todos los Sábados</div>
                </div>
            </div>
            <div class="vc-spec-card reveal stagger-2">
                <div class="vc-spec-card__photo">
                    <div class="vc-spec-card__avatar vc-spec-card__avatar--coral" style="display:flex"><Icon Name="cat" Size="28" /></div>
                </div>
                <div class="vc-spec-card__body">
                    <h3>Dra. Pilar Muñoz</h3>
                    <span class="vc-spec-card__role">Medicina Felina</span>
                    <p>Especialista exclusiva en gatos. Atención en un ambiente diseñado para felinos.</p>
                    <div class="vc-spec-card__meta"><Icon Name="calendar" Size="14" /> Agenda Disponible</div>
                </div>
            </div>
            <div class="vc-spec-card reveal stagger-3">
                <div class="vc-spec-card__photo">
                    <div class="vc-spec-card__avatar vc-spec-card__avatar--purple" style="display:flex"><Icon Name="flask" Size="28" /></div>
                </div>
                <div class="vc-spec-card__body">
                    <h3>Endocrinología</h3>
                    <span class="vc-spec-card__role">Especialista Visitante</span>
                    <p>Diabetes, tiroides y condiciones endocrinas en pequeños animales.</p>
                    <div class="vc-spec-card__meta"><Icon Name="calendar" Size="14" /> Consultar disponibilidad</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ VET MÓVIL -->
<section class="vc-section vc-section--soft">
    <div class="vc-w">
        <div class="vc-vetmovil reveal">
            <div class="vc-vetmovil__text">
                <span class="vc-tag">Atención a Domicilio</span>
                <h2>San Pablo<br />Vet Móvil</h2>
                <p>
                    Llevamos la atención veterinaria profesional a la puerta de tu casa.
                    Ideal para mascotas que se estresan con los viajes o tutores con movilidad reducida.
                </p>
                <ul class="vc-check-list">
                    <li><Icon Name="check" Size="16" /> Consultas veterinarias completas</li>
                    <li><Icon Name="check" Size="16" /> Vacunación y toma de muestras</li>
                    <li><Icon Name="check" Size="16" /> Control de pacientes crónicos</li>
                    <li><Icon Name="check" Size="16" /> Lunes a Domingo, 09:00 a 16:30 hrs</li>
                </ul>
                <a href="@AppConstants.Urls.WhatsAppMobileVetLink" target="_blank" class="vc-btn vc-btn--coral">
                    <Icon Name="phone" Size="18" /> Agendar Visita · @AppConstants.Phone.MobileVetWhatsAppFormatted
                </a>
            </div>
            <div class="vc-vetmovil__img">
                <img src="@ImagePaths.Services.VetMovil" alt="Servicio veterinario a domicilio"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="vc-vetmovil__img-fallback">
                    <Icon Name="van" Size="52" />
                    <span>Servicio Móvil</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ UBICACIÓN RÁPIDA -->
<section class="vc-location">
    <div class="vc-w">
        <div class="vc-location__inner reveal">
            <div class="vc-location__info">
                <span class="vc-tag">Encuéntranos</span>
                <h2>Ubicación</h2>
                <p><Icon Name="location" Size="16" /> @AppConstants.Clinic.FullAddress</p>
                <p><Icon Name="clock" Size="16" /> Abierto las 24 horas, todos los días</p>
                <p><Icon Name="phone" Size="16" /> @AppConstants.Phone.MainWhatsAppFormatted</p>
                <div class="vc-location__actions">
                    <a href="@AppConstants.Maps.DirectionsUrl" target="_blank" class="vc-btn vc-btn--dark">
                        <Icon Name="location" Size="18" /> Ver en Google Maps
                    </a>
                    <a href="contacto" class="vc-btn vc-btn--outline">
                        <Icon Name="phone" Size="18" /> Contacto
                    </a>
                </div>
            </div>
            <div class="vc-location__map">
                <div class="vc-location__map-fallback" style="display:flex">
                    <Icon Name="location" Size="40" />
                    <span>Rancagua, Chile</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ CONÓCENOS -->
<section class="vc-about">
    <div class="vc-w">
        <div class="vc-about__grid reveal">
            <div class="vc-about__img">
                <img src="@ImagePaths.Clinic.Fachada" alt="Fachada San Pablo Vet Clínic"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="vc-about__img-fallback">
                    <Icon Name="paw" Size="48" />
                </div>
                <div class="vc-about__badge">
                    <strong>Desde 2014</strong>
                </div>
            </div>
            <div class="vc-about__text">
                <span class="vc-tag">Quiénes Somos</span>
                <h2>Más que una clínica</h2>
                <p>
                    En San Pablo Vet Clínic nos apasiona la medicina veterinaria. Desde 2014 hemos
                    construido un equipo multidisciplinario con especialistas en diversas áreas,
                    tecnología de diagnóstico de última generación y un compromiso genuino con cada paciente.
                </p>
                <ul class="vc-check-list">
                    <li><Icon Name="check" Size="16" /> Urgencias 24 horas, los 365 días del año</li>
                    <li><Icon Name="check" Size="16" /> Especialistas certificados en múltiples áreas</li>
                    <li><Icon Name="check" Size="16" /> Laboratorio IDEXX para diagnósticos precisos</li>
                    <li><Icon Name="check" Size="16" /> Atención veterinaria a domicilio</li>
                </ul>
                <a href="conocenos" class="vc-btn vc-btn--dark">
                    <Icon Name="heart" Size="18" /> Conoce nuestra historia
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ▸ CTA FINAL -->
<section class="vc-cta">
    <div class="vc-cta__inner reveal">
        <span class="vc-tag">Disponible 24/7</span>
        <h2>¿Tu mascota necesita<br />atención <em>ahora</em>?</h2>
        <div class="vc-cta__btns">
            <a href="contacto" class="vc-btn vc-btn--coral vc-btn--lg">
                <Icon Name="alarm" Size="20" /> Urgencias 24/7
            </a>
            <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="vc-btn vc-btn--glass vc-btn--lg">
                <Icon Name="calendar" Size="20" /> Agendar Consulta
            </a>
        </div>
        <div class="vc-cta__addr">
            <Icon Name="location" Size="14" /> @AppConstants.Clinic.FullAddress
        </div>
    </div>
</section>

<div class="vc-back">
    <NavLink href="variantes" class="vc-back__link">← Volver a las variantes</NavLink>
</div>

<!-- ========== STYLES ========== -->
<style>
    /* ===== VARIABLES LOCALES ===== */
    .vc-hero-carousel,
    .vc-quick-bar,
    .vc-about,
    .vc-section,
    .vc-location,
    .vc-cta,
    .vc-back {
        --vc-dark: #0d0d0d;
        --vc-dark-2: #111;
        --vc-dark-3: #1a1a1a;
        --vc-white-10: rgba(255,255,255,0.10);
        --vc-white-06: rgba(255,255,255,0.06);
        --vc-white-60: rgba(255,255,255,0.60);
        --vc-white-35: rgba(255,255,255,0.35);
    }

    /* ===== UTILIDADES ===== */
    .vc-w { max-width: 1100px; margin: 0 auto; }

    .vc-tag {
        display: inline-block;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--accent-coral);
        text-transform: uppercase;
        letter-spacing: 0.15em;
    }

    .vc-accent {
        background: linear-gradient(135deg, var(--primary-teal), #87d4e8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .vc-check-list {
        list-style: none;
        padding: 0;
        margin: 0 0 1.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .vc-check-list li {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: var(--font-size-sm);
        color: var(--text-dark);
        font-weight: 500;
    }

    .vc-check-list--light li { color: var(--vc-white-60); }

    /* ===== BOTONES ===== */
    .vc-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.875rem 1.75rem;
        border-radius: var(--border-radius);
        font-weight: 700;
        font-size: var(--font-size-base);
        text-decoration: none;
        transition: var(--transition);
        border: 2px solid transparent;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .vc-btn--lg { padding: 1rem 2.25rem; font-size: 1.0625rem; }

    .vc-btn--coral {
        background: var(--accent-coral);
        color: white;
        border-color: var(--accent-coral);
    }

    .vc-btn--coral:hover {
        background: var(--accent-coral-dark);
        border-color: var(--accent-coral-dark);
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(187,84,95,0.4);
    }

    .vc-btn--glass {
        background: rgba(255,255,255,0.08);
        color: white;
        border-color: rgba(255,255,255,0.2);
        backdrop-filter: blur(8px);
    }

    .vc-btn--glass:hover {
        background: rgba(255,255,255,0.15);
        border-color: rgba(255,255,255,0.4);
    }

    .vc-btn--dark {
        background: var(--text-dark);
        color: white;
        border-color: var(--text-dark);
    }

    .vc-btn--dark:hover {
        background: #000;
        transform: translateY(-2px);
        box-shadow: var(--shadow-medium);
    }

    .vc-btn--outline {
        background: transparent;
        color: var(--text-dark);
        border-color: #d4d8dd;
    }

    .vc-btn--outline:hover { border-color: var(--primary-teal); color: var(--primary-teal); }

    /* ===== HERO CAROUSEL ===== */
    .vc-hero-carousel {
        min-height: var(--hero-height, 100vh);
        position: relative;
        overflow: hidden;
        background: var(--vc-dark);
    }

    .vc-hc__slide {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.8s ease, visibility 0.8s ease;
    }

    .vc-hc__slide.active {
        opacity: 1;
        visibility: visible;
    }

    .vc-hc__bg { position: absolute; inset: 0; }

    .vc-hc__bg img {
        width: 100%; height: 100%;
        object-fit: cover;
        opacity: 0.3;
        filter: grayscale(20%);
    }

    .vc-hc__overlay {
        position: absolute; inset: 0;
        background: linear-gradient(180deg, rgba(13,13,13,0.4) 0%, rgba(13,13,13,0.85) 100%);
    }

    .vc-hc__content {
        position: relative; z-index: 1;
        max-width: 800px; padding: 4rem 2rem;
    }

    .vc-hc__tag {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--accent-coral);
        font-size: var(--font-size-sm);
        font-weight: 700;
        letter-spacing: 0.15em;
        margin-bottom: 1.5rem;
    }

    .vc-pulse {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: var(--accent-coral);
        animation: vc-pulse 1.5s ease-in-out infinite;
    }

    @@keyframes vc-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(187,84,95,0.5); }
        50% { box-shadow: 0 0 0 8px rgba(187,84,95,0); }
    }

    .vc-hc__title {
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 800;
        color: white;
        line-height: 1.05;
        margin: 0 0 1rem;
        letter-spacing: -0.04em;
    }

    .vc-hc__sub {
        font-size: 1.0625rem;
        color: var(--vc-white-60);
        margin: 0 0 2.5rem;
        letter-spacing: 0.02em;
        line-height: 1.6;
    }

    .vc-hc__btns {
        display: flex; gap: 1rem;
        justify-content: center; flex-wrap: wrap;
    }

    /* Carousel dots */
    .vc-hc__dots {
        position: absolute;
        bottom: 2rem; left: 50%; transform: translateX(-50%);
        display: flex; gap: 0.75rem;
        z-index: 10;
    }

    .vc-hc__dot {
        width: 10px; height: 10px;
        border-radius: 50%;
        background: rgba(255,255,255,0.3);
        border: none; padding: 0;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .vc-hc__dot.active {
        background: white;
        width: 28px;
        border-radius: 5px;
    }

    .vc-hc__dot:hover { background: rgba(255,255,255,0.6); }

    /* Carousel navigation */
    .vc-hc__nav {
        position: absolute;
        top: 50%; transform: translateY(-50%);
        width: 48px; height: 48px;
        border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.15);
        background: rgba(0,0,0,0.25);
        color: white; font-size: 1.5rem;
        cursor: pointer; z-index: 10;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.3s ease;
        backdrop-filter: blur(4px);
    }

