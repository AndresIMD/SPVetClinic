@page "/home-a"

<PageTitle>San Pablo Vet Clínic - Clínica Veterinaria en Rancagua</PageTitle>
<HeadContent>
    <meta name="description"
          content="Clínica veterinaria en Rancagua con urgencias 24/7. Especialistas certificados, laboratorio IDEXX y atención a domicilio." />
</HeadContent>

<!-- ============================================
     VARIANTE A: HOSPITAL ELEGANTE (v2)
     Minimalista, sofisticado, mucho espacio blanco.
     Imágenes grandes, urgencias prominente.
     Sin testimonios ni métricas numéricas.
     ============================================ -->

<!-- HERO: Imagen de fachada con texto sobrepuesto -->
<section class="va-hero">
    <div class="va-hero__image-bg">
        <img src="@ImagePaths.Clinic.Fachada"
             alt="Fachada de San Pablo Vet Clínic"
             class="va-hero__bg-photo"
             onerror="this.style.display='none'" />
        <div class="va-hero__overlay"></div>
    </div>
    <div class="va-hero__content">
        <span class="va-hero__badge">
            <Icon Name="shield" Size="16" /> Clínica Veterinaria · @AppConstants.Clinic.City
        </span>
        <h1 class="va-hero__title">
            Medicina veterinaria<br />de <em>excelencia</em>
        </h1>
        <p class="va-hero__subtitle">
            Atención las 24 horas con especialistas certificados, tecnología IDEXX
            y un equipo comprometido con el bienestar de tu mascota.
        </p>
        <div class="va-hero__actions">
            <a href="@AppConstants.Urls.WhatsAppMainLink" target="_blank" class="va-btn va-btn--urgent">
                <Icon Name="alarm" Size="18" /> Urgencias 24/7
            </a>
            <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="va-btn va-btn--white">
                <Icon Name="calendar" Size="18" /> Agendar Consulta
            </a>
        </div>
    </div>
</section>

<!-- BARRA DE ACCESO RÁPIDO -->
<section class="va-quick-bar">
    <div class="va-quick-bar__inner">
        <div class="va-quick-bar__item">
            <Icon Name="alarm" Size="20" />
            <div>
                <strong>Urgencias 24/7</strong>
                <span>Todos los días, incluidos festivos</span>
            </div>
        </div>
        <div class="va-quick-bar__divider"></div>
        <div class="va-quick-bar__item">
            <Icon Name="van" Size="20" />
            <div>
                <strong>Atención a Domicilio</strong>
                <span>Vet Móvil en Rancagua y alrededores</span>
            </div>
        </div>
        <div class="va-quick-bar__divider"></div>
        <div class="va-quick-bar__item">
            <Icon Name="brain" Size="20" />
            <div>
                <strong>Especialistas</strong>
                <span>Neurología · Felina · Endocrinología</span>
            </div>
        </div>
        <a href="@AppConstants.Urls.WhatsAppMainLink" target="_blank" class="va-quick-bar__btn">
            <Icon Name="phone" Size="16" /> @AppConstants.Phone.MainWhatsAppFormatted
        </a>
    </div>
</section>

<!-- SERVICIOS: Grid con imágenes reales -->
<section class="va-section">
    <div class="va-container">
        <div class="va-section-header">
            <span class="va-overline">Servicios</span>
            <h2>Atención integral en un solo lugar</h2>
        </div>

        <div class="va-services-grid">
            <div class="va-service-card reveal stagger-1">
                <div class="va-service-card__img no-img">
                    <div class="va-service-card__icon-fallback"><Icon Name="stethoscope" Size="32" /></div>
                </div>
                <div class="va-service-card__body">
                    <h3>Consulta General</h3>
                    <p>Evaluaciones completas, diagnósticos precisos y planes de tratamiento personalizados.</p>
                </div>
            </div>
            <div class="va-service-card reveal stagger-2">
                <div class="va-service-card__img">
                    <img src="@ImagePaths.Services.Examenes" alt="Muestras de laboratorio"
                         onerror="this.parentElement.classList.add('no-img')" />
                    <div class="va-service-card__icon-fallback"><Icon Name="microscope" Size="32" /></div>
                </div>
                <div class="va-service-card__body">
                    <h3>Laboratorio IDEXX</h3>
                    <p>Hemogramas, bioquímica, PCR y diagnóstico por imágenes con resultados rápidos.</p>
                </div>
            </div>
            <div class="va-service-card reveal stagger-3">
                <div class="va-service-card__img">
                    <img src="@ImagePaths.Services.Cirugia" alt="Cirugía veterinaria"
                         onerror="this.parentElement.classList.add('no-img')" />
                    <div class="va-service-card__icon-fallback"><Icon Name="syringe" Size="32" /></div>
                </div>
                <div class="va-service-card__body">
                    <h3>Cirugía y Hospitalización</h3>
                    <p>Procedimientos quirúrgicos seguros con monitoreo constante y cuidados post-operatorios.</p>
                </div>
            </div>
            <div class="va-service-card reveal stagger-4">
                <div class="va-service-card__img no-img">
                    <div class="va-service-card__icon-fallback"><Icon Name="pill" Size="32" /></div>
                </div>
                <div class="va-service-card__body">
                    <h3>Vacunación y Prevención</h3>
                    <p>Programas de vacunación, desparasitación y medicina preventiva para cada etapa de vida.</p>
                </div>
            </div>
            <div class="va-service-card reveal stagger-5">
                <div class="va-service-card__img no-img">
                    <div class="va-service-card__icon-fallback"><Icon Name="scissors" Size="32" /></div>
                </div>
                <div class="va-service-card__body">
                    <h3>Peluquería y Estética</h3>
                    <p>Baños medicados, cortes profesionales y cuidado integral para la higiene de tu mascota.</p>
                </div>
            </div>
            <div class="va-service-card reveal stagger-6">
                <div class="va-service-card__img no-img">
                    <div class="va-service-card__icon-fallback"><Icon Name="chart" Size="32" /></div>
                </div>
                <div class="va-service-card__body">
                    <h3>Imagenología</h3>
                    <p>Ecografía, radiografía y electrocardiograma para diagnósticos certeros y oportunos.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ESPECIALISTAS con placeholder para fotos reales -->
<section class="va-section va-section--alt">
    <div class="va-container">
        <div class="va-section-header">
            <span class="va-overline">Equipo Médico</span>
            <h2>Especialistas certificados</h2>
        </div>

        <div class="va-specialists">
            <div class="va-specialist reveal stagger-1">
                <div class="va-specialist__photo">
                    <div class="va-specialist__avatar" style="display:flex"><Icon Name="brain" Size="32" /></div>
                </div>
                <div class="va-specialist__info">
                    <h3>Dr. Hernán Vargas</h3>
                    <span class="va-specialist__role">Neurología Veterinaria</span>
                    <p>Especialista en convulsiones, problemas de equilibrio, dolor de cuello y movimientos anormales. Más de 15 años de experiencia.</p>
                    <span class="va-specialist__schedule"><Icon Name="calendar" Size="14" /> Todos los Sábados</span>
                </div>
            </div>
            <div class="va-specialist reveal stagger-2">
                <div class="va-specialist__photo">
                    <div class="va-specialist__avatar va-specialist__avatar--coral" style="display:flex"><Icon Name="cat" Size="32" /></div>
                </div>
                <div class="va-specialist__info">
                    <h3>Dra. Pilar Muñoz</h3>
                    <span class="va-specialist__role">Medicina Felina</span>
                    <p>Especialista exclusiva en gatos. Atención cuidadosa y personalizada en un ambiente diseñado para felinos.</p>
                    <span class="va-specialist__schedule"><Icon Name="calendar" Size="14" /> Agenda Disponible</span>
                </div>
            </div>
            <div class="va-specialist reveal stagger-3">
                <div class="va-specialist__photo">
                    <div class="va-specialist__avatar va-specialist__avatar--purple" style="display:flex"><Icon Name="flask" Size="32" /></div>
                </div>
                <div class="va-specialist__info">
                    <h3>Endocrinología</h3>
                    <span class="va-specialist__role">Especialista Visitante</span>
                    <p>Tratamiento de problemas hormonales, diabetes, tiroides y condiciones endocrinas en pequeños animales.</p>
                    <span class="va-specialist__schedule"><Icon Name="calendar" Size="14" /> Consultar disponibilidad</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- VET MÓVIL: Sección destacada -->
<section class="va-section">
    <div class="va-container">
        <div class="va-vetmovil reveal">
            <div class="va-vetmovil__img">
                <img src="@ImagePaths.Services.VetMovil" alt="Servicio veterinario a domicilio"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="va-vetmovil__img-fallback">
                    <Icon Name="van" Size="56" />
                    <span>Servicio a Domicilio</span>
                </div>
            </div>
            <div class="va-vetmovil__content">
                <span class="va-overline">Atención a Domicilio</span>
                <h2>San Pablo Vet Móvil</h2>
                <p>Llevamos la atención veterinaria profesional hasta la puerta de tu casa. Ideal para mascotas que se estresan con los viajes o para tutores con movilidad reducida.</p>
                <ul class="va-vetmovil__list">
                    <li><Icon Name="check" Size="16" /> Consultas veterinarias</li>
                    <li><Icon Name="check" Size="16" /> Vacunación y toma de muestras</li>
                    <li><Icon Name="check" Size="16" /> Control de pacientes crónicos</li>
                    <li><Icon Name="check" Size="16" /> Lunes a Domingo, 09:00 a 16:30 hrs</li>
                </ul>
                <a href="@AppConstants.Urls.WhatsAppMobileVetLink" target="_blank" class="va-btn va-btn--primary">
                    <Icon Name="phone" Size="18" /> Agendar Visita · @AppConstants.Phone.MobileVetWhatsAppFormatted
                </a>
            </div>
        </div>
    </div>
</section>

<!-- CTA FINAL -->
<section class="va-cta">
    <div class="va-cta__content reveal">
        <h2>Tu mascota merece la mejor atención</h2>
        <p>Agenda tu consulta o contáctanos directamente. Estamos disponibles las 24 horas.</p>
        <div class="va-cta__actions">
            <a href="@AppConstants.Urls.WhatsAppMainLink" target="_blank" class="va-btn va-btn--white">
                <Icon Name="alarm" Size="18" /> Urgencias 24/7
            </a>
            <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="va-btn va-btn--ghost">
                <Icon Name="calendar" Size="18" /> Agendar Hora
            </a>
        </div>
        <div class="va-cta__address">
            <Icon Name="location" Size="16" /> @AppConstants.Clinic.FullAddress · <Icon Name="clock" Size="16" /> 24 horas, todos los días
        </div>
    </div>
</section>

<div class="va-back-selector">
    <NavLink href="variantes" class="va-back-link">← Volver a las variantes</NavLink>
</div>

<style>
    /* --- HERO CON IMAGEN DE FACHADA --- */
    .va-hero {
        min-height: var(--hero-height, 100vh);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 4rem 2rem;
        position: relative;
        overflow: hidden;
        background: #0a1a1f;
    }

    .va-hero__image-bg { position: absolute; inset: 0; }

    .va-hero__bg-photo {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .va-hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(10,26,31,0.5) 0%, rgba(10,26,31,0.72) 100%);
    }

    .va-hero__content {
        max-width: 720px;
        position: relative;
        z-index: 1;
    }

    .va-hero__badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(8px);
        color: rgba(255,255,255,0.9);
        padding: 0.5rem 1.25rem;
        border-radius: var(--border-radius-pill);
        font-size: var(--font-size-sm);
        font-weight: 600;
        margin-bottom: 1.5rem;
        border: 1px solid rgba(255,255,255,0.15);
    }

    .va-hero__title {
        font-size: clamp(2.5rem, 5vw, 3.75rem);
        font-weight: 700;
        color: white;
        line-height: 1.15;
        margin: 0 0 1.25rem;
        letter-spacing: -0.03em;
    }

    .va-hero__title em { font-style: italic; color: var(--primary-teal); }

    .va-hero__subtitle {
        font-size: 1.125rem;
        color: rgba(255,255,255,0.8);
        line-height: 1.8;
        margin: 0 auto 2rem;
        max-width: 580px;
    }

    .va-hero__actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

    /* --- BUTTONS --- */
    .va-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.875rem 1.75rem;
        border-radius: var(--border-radius);
        font-weight: 600;
        font-size: var(--font-size-base);
        text-decoration: none;
        transition: var(--transition);
        border: 2px solid transparent;
    }

    .va-btn--urgent {
        background: var(--accent-coral);
        color: white;
        border-color: var(--accent-coral);
        animation: va-pulse 2s ease-in-out infinite;
    }

    .va-btn--urgent:hover {
        background: var(--accent-coral-dark);
        border-color: var(--accent-coral-dark);
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(187,84,95,0.4);
        animation: none;
    }

    @@keyframes va-pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(187,84,95,0.4); }
        50% { box-shadow: 0 0 0 8px rgba(187,84,95,0); }
    }

    .va-btn--primary {
        background: var(--primary-teal);
        color: white;
        border-color: var(--primary-teal);
    }

    .va-btn--primary:hover {
        background: var(--primary-teal-dark);
        border-color: var(--primary-teal-dark);
        transform: translateY(-2px);
        box-shadow: var(--shadow-medium);
    }

    .va-btn--white {
        background: white;
        color: var(--primary-teal-dark);
        border-color: white;
    }

    .va-btn--white:hover {
        background: var(--primary-teal-light);
        transform: translateY(-2px);
        box-shadow: var(--shadow-medium);
    }

    .va-btn--ghost {
        background: transparent;
        color: white;
        border-color: rgba(255,255,255,0.4);
    }

    .va-btn--ghost:hover {
        background: rgba(255,255,255,0.1);
        border-color: white;
    }

    /* --- QUICK ACCESS BAR --- */
    .va-quick-bar {
        background: var(--bg-white);
        border-bottom: 1px solid #eef1f5;
        padding: 0.5rem 2rem;
    }

    .va-quick-bar__inner {
        max-width: 1200px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .va-quick-bar__item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 2rem;
        color: var(--text-dark);
    }

    .va-quick-bar__item strong { display: block; font-size: var(--font-size-base); font-weight: 600; }
    .va-quick-bar__item span { font-size: var(--font-size-sm); color: var(--text-gray); }

    .va-quick-bar__divider { width: 1px; height: 36px; background: #eef1f5; }

    .va-quick-bar__btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--primary-teal);
        color: white;
        padding: 0.6rem 1.25rem;
        border-radius: var(--border-radius);
        font-weight: 600;
        font-size: var(--font-size-sm);
        text-decoration: none;
        margin-left: auto;
        transition: var(--transition);
    }

    .va-quick-bar__btn:hover { background: var(--primary-teal-dark); transform: translateY(-1px); }

    /* --- SECTIONS --- */
    .va-section { padding: 5rem 2rem; }
    .va-section--alt { background: #f8fafb; }
    .va-container { max-width: 1100px; margin: 0 auto; }
    .va-section-header { text-align: center; margin-bottom: 3rem; }

    .va-overline {
        display: block;
        font-size: var(--font-size-sm);
        font-weight: 600;
        color: var(--primary-teal);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.5rem;
    }

    .va-section-header h2 { font-size: var(--font-size-h2); color: var(--text-dark); margin: 0; font-weight: 700; }

    /* --- SERVICES WITH IMAGES --- */
    .va-services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

    .va-service-card {
        background: white;
        border: 1px solid #eef1f5;
        border-radius: var(--border-radius);
        overflow: hidden;
        transition: var(--transition);
    }

    .va-service-card:hover {
        border-color: var(--primary-teal);
        box-shadow: var(--shadow-soft);
        transform: translateY(-3px);
    }

    .va-service-card__img {
        height: 160px;
        background: var(--primary-teal-light);
        overflow: hidden;
        position: relative;
    }

    .va-service-card__img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease;
    }

    .va-service-card:hover .va-service-card__img img { transform: scale(1.05); }

    .va-service-card__icon-fallback {
        position: absolute;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        color: var(--primary-teal);
        background: var(--primary-teal-light);
    }

    .va-service-card__img.no-img img { display: none; }
    .va-service-card__img.no-img .va-service-card__icon-fallback { display: flex; }

    .va-service-card__body { padding: 1.5rem; }
    .va-service-card__body h3 { font-size: 1.0625rem; font-weight: 600; color: var(--text-dark); margin: 0 0 0.5rem; }
    .va-service-card__body p { font-size: var(--font-size-sm); color: var(--text-gray); line-height: 1.6; margin: 0; }

    /* --- SPECIALISTS --- */
    .va-specialists { display: flex; flex-direction: column; gap: 1.25rem; }

    .va-specialist {
        display: flex;
        gap: 1.5rem;
        align-items: flex-start;
        background: white;
        padding: 1.75rem;
        border-radius: var(--border-radius);
        border: 1px solid #eef1f5;
        transition: var(--transition);
    }

    .va-specialist:hover { box-shadow: var(--shadow-soft); border-color: var(--primary-teal); }

    .va-specialist__photo {
        width: 80px; height: 80px;
        flex-shrink: 0;
        border-radius: 14px;
        overflow: hidden;
    }

    .va-specialist__photo img { width: 100%; height: 100%; object-fit: cover; }

    .va-specialist__avatar {
        width: 80px; height: 80px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--primary-teal), var(--primary-teal-dark));
        display: none;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .va-specialist__avatar--coral { background: linear-gradient(135deg, var(--accent-coral), var(--accent-coral-dark)); }
    .va-specialist__avatar--purple { background: linear-gradient(135deg, #8e44ad, #6c3483); }

    .va-specialist__info h3 { font-size: 1.0625rem; font-weight: 700; color: var(--text-dark); margin: 0 0 0.15rem; }
    .va-specialist__role { font-size: var(--font-size-sm); color: var(--primary-teal); font-weight: 600; }
    .va-specialist__info p { font-size: var(--font-size-sm); color: var(--text-gray); line-height: 1.6; margin: 0.5rem 0; }
    .va-specialist__schedule { font-size: var(--font-size-sm); color: var(--text-gray); display: inline-flex; align-items: center; gap: 4px; }

    /* --- VET MÓVIL --- */
    .va-vetmovil {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        align-items: stretch;
        background: var(--primary-teal-light);
        border-radius: 16px;
        overflow: hidden;
    }

    .va-vetmovil__img {
        min-height: 350px;
        position: relative;
        overflow: hidden;
    }

    .va-vetmovil__img img { width: 100%; height: 100%; object-fit: cover; }

    .va-vetmovil__img-fallback {
        display: none;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        height: 100%;
        color: var(--primary-teal);
        font-weight: 600;
    }

    .va-vetmovil__content { padding: 2.5rem; }
    .va-vetmovil__content h2 { font-size: var(--font-size-h2); color: var(--text-dark); margin: 0.25rem 0 0.75rem; }
    .va-vetmovil__content > p { color: var(--text-gray); line-height: 1.7; margin: 0 0 1.25rem; }

    .va-vetmovil__list {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .va-vetmovil__list li {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: var(--font-size-sm);
        color: var(--text-dark);
    }

    /* --- CTA --- */
    .va-cta {
        background: linear-gradient(135deg, var(--primary-teal) 0%, var(--primary-teal-dark) 100%);
        padding: 5rem 2rem;
        text-align: center;
    }

    .va-cta__content { max-width: 600px; margin: 0 auto; }
    .va-cta h2 { font-size: var(--font-size-h2); color: white; margin: 0 0 0.75rem; font-weight: 700; }
    .va-cta p { color: rgba(255,255,255,0.9); line-height: 1.7; margin: 0 0 2rem; }
    .va-cta__actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
    .va-cta__address { margin-top: 2rem; color: rgba(255,255,255,0.7); font-size: var(--font-size-sm); display: flex; align-items: center; justify-content: center; gap: 0.35rem; flex-wrap: wrap; }

    .va-back-selector { text-align: center; padding: 1.5rem; background: #f8fafb; }
    .va-back-link { color: var(--primary-teal); text-decoration: none; font-weight: 600; font-size: var(--font-size-sm); }
    .va-back-link:hover { text-decoration: underline; }

    @@media (max-width: 768px) {
        .va-quick-bar__inner { flex-wrap: wrap; }
        .va-quick-bar__divider { display: none; }
        .va-quick-bar__item { padding: 0.75rem 1rem; }
        .va-quick-bar__btn { margin: 0.5rem auto 0; width: 100%; justify-content: center; }
        .va-services-grid { grid-template-columns: 1fr; }
        .va-specialist { flex-direction: column; }
        .va-vetmovil { grid-template-columns: 1fr; }
        .va-vetmovil__img { min-height: 220px; }
    }
</style>
