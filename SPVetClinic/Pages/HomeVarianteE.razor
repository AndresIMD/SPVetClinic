@page "/home-e"
@layout VariantCLayout
@implements IDisposable

<PageTitle>San Pablo Vet Clínic — Clínica Veterinaria en Rancagua</PageTitle>
<HeadContent>
    <meta name="description"
          content="Clínica veterinaria en Rancagua con urgencias 24/7. Especialistas certificados, laboratorio IDEXX y atención a domicilio." />
</HeadContent>

<!-- ============================================
     VARIANTE E — EDITORIAL VISUAL
     Asimétrico, fotografías grandes, layout
     tipo revista. Secciones anchas con imágenes
     prominentes. Blanco dominante, negro acento.
     ============================================ -->

<!-- ▸ HERO CAROUSEL (más cinematográfico) -->
<section class="ve-hero" @onmouseenter="OnHeroEnter" @onmouseleave="OnHeroLeave">
    <div class="ve-hero__slide @(currentSlide == 0 ? "active" : "")">
        <div class="ve-hero__bg">
            <img src="@ImagePaths.Hero.Frontage"
                 alt="Fachada San Pablo Vet Clínic" onerror="this.style.display='none'" />
        </div>
        <div class="ve-hero__overlay"></div>
        <div class="ve-hero__content">
            <div class="ve-hero__tag"><span class="ve-pulse"></span> URGENCIAS 24/7</div>
            <h1>Cuidamos lo que<br />más <span class="ve-accent">importa</span></h1>
            <p>Clínica veterinaria con especialistas certificados en @AppConstants.Clinic.City</p>
            <div class="ve-hero__btns">
                <a href="contacto" class="ve-btn ve-btn--coral"><Icon Name="alarm" Size="18" /> Emergencia</a>
                <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="ve-btn ve-btn--glass"><Icon Name="calendar" Size="18" /> Reservar</a>
            </div>
        </div>
    </div>
    <div class="ve-hero__slide @(currentSlide == 1 ? "active" : "")">
        <div class="ve-hero__bg">
            <img src="@ImagePaths.Services.Cirugia" alt="Cirugía veterinaria" onerror="this.style.display='none'" />
        </div>
        <div class="ve-hero__overlay"></div>
        <div class="ve-hero__content">
            <div class="ve-hero__tag"><span class="ve-pulse"></span> EQUIPO ESPECIALIZADO</div>
            <h1>Especialistas<br /><span class="ve-accent">certificados</span></h1>
            <p>Neurología · Medicina Felina · Endocrinología · Cirugía avanzada</p>
            <div class="ve-hero__btns">
                <a href="especialistas" class="ve-btn ve-btn--coral"><Icon Name="brain" Size="18" /> Especialistas</a>
                <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="ve-btn ve-btn--glass"><Icon Name="calendar" Size="18" /> Agendar</a>
            </div>
        </div>
    </div>
    <div class="ve-hero__slide @(currentSlide == 2 ? "active" : "")">
        <div class="ve-hero__bg">
            <img src="@ImagePaths.Services.Examenes" alt="Laboratorio veterinario" onerror="this.style.display='none'" />
        </div>
        <div class="ve-hero__overlay"></div>
        <div class="ve-hero__content">
            <div class="ve-hero__tag"><span class="ve-pulse"></span> TECNOLOGÍA DE PUNTA</div>
            <h1>Diagnósticos<br /><span class="ve-accent">precisos</span></h1>
            <p>Laboratorio IDEXX · Imagenología · Resultados rápidos y confiables</p>
            <div class="ve-hero__btns">
                <a href="servicios" class="ve-btn ve-btn--coral"><Icon Name="microscope" Size="18" /> Servicios</a>
                <a href="@AppConstants.Urls.WhatsAppMobileVetLink" target="_blank" class="ve-btn ve-btn--glass"><Icon Name="van" Size="18" /> Vet Móvil</a>
            </div>
        </div>
    </div>

    <div class="ve-hero__dots">
        <button class="ve-hero__dot @(currentSlide == 0 ? "active" : "")" @onclick="() => GoToSlide(0)"></button>
        <button class="ve-hero__dot @(currentSlide == 1 ? "active" : "")" @onclick="() => GoToSlide(1)"></button>
        <button class="ve-hero__dot @(currentSlide == 2 ? "active" : "")" @onclick="() => GoToSlide(2)"></button>
    </div>
    <button class="ve-hero__nav ve-hero__nav--prev" @onclick="PrevSlide" aria-label="Anterior">‹</button>
    <button class="ve-hero__nav ve-hero__nav--next" @onclick="NextSlide" aria-label="Siguiente">›</button>
</section>

<!-- ▸ URGENCIA STRIP (slim coral accent) -->
<section class="ve-urg-strip">
    <div class="ve-w-wide">
        <div class="ve-urg-strip__inner">
            <span class="ve-pulse"></span>
            <strong>Urgencias 24/7</strong>
            <span class="ve-urg-strip__sep">·</span>
            <span>@AppConstants.Phone.MainWhatsAppFormatted</span>
            <span class="ve-urg-strip__sep">·</span>
            <span>@AppConstants.Clinic.FullAddress</span>
            <a href="contacto" class="ve-urg-strip__link">Contactar →</a>
        </div>
    </div>
</section>

<!-- ▸ SERVICIOS DESTACADOS (editorial: imagen grande + texto) -->
<section class="ve-section">
    <div class="ve-w">
        <div class="ve-sh">
            <span class="ve-tag">Servicios</span>
            <h2>Atención integral</h2>
        </div>
    </div>
    <div class="ve-w-wide">
        <div class="ve-feat">
            <div class="ve-feat__card reveal stagger-1">
                <div class="ve-feat__img no-img">
                    <div class="ve-feat__img-fb"><Icon Name="stethoscope" Size="36" /></div>
                </div>
                <div class="ve-feat__body">
                    <span class="ve-feat__num">01</span>
                    <h3>Consulta General</h3>
                    <p>Evaluaciones completas, diagnósticos precisos y planes de tratamiento personalizados para cada paciente.</p>
                    <ul class="ve-feat__list">
                        <li><Icon Name="check" Size="14" /> Examen físico completo</li>
                        <li><Icon Name="check" Size="14" /> Plan de tratamiento personalizado</li>
                        <li><Icon Name="check" Size="14" /> Seguimiento continuo</li>
                    </ul>
                </div>
            </div>
            <div class="ve-feat__card ve-feat__card--rev reveal stagger-2">
                <div class="ve-feat__img">
                    <img src="@ImagePaths.Services.Examenes" alt="Laboratorio IDEXX"
                         onerror="this.parentElement.classList.add('no-img')" />
                    <div class="ve-feat__img-fb"><Icon Name="microscope" Size="36" /></div>
                </div>
                <div class="ve-feat__body">
                    <span class="ve-feat__num">02</span>
                    <h3>Laboratorio IDEXX</h3>
                    <p>Hemogramas, bioquímica, PCR y diagnóstico por imágenes con resultados rápidos y confiables.</p>
                    <ul class="ve-feat__list">
                        <li><Icon Name="check" Size="14" /> Resultados en minutos</li>
                        <li><Icon Name="check" Size="14" /> Tecnología de referencia mundial</li>
                        <li><Icon Name="check" Size="14" /> Perfiles completos de laboratorio</li>
                    </ul>
                </div>
            </div>
            <div class="ve-feat__card reveal stagger-3">
                <div class="ve-feat__img">
                    <img src="@ImagePaths.Services.Cirugia" alt="Cirugía veterinaria"
                         onerror="this.parentElement.classList.add('no-img')" />
                    <div class="ve-feat__img-fb"><Icon Name="syringe" Size="36" /></div>
                </div>
                <div class="ve-feat__body">
                    <span class="ve-feat__num">03</span>
                    <h3>Cirugía y Hospitalización</h3>
                    <p>Procedimientos seguros con monitoreo constante, equipo especializado y cuidados post-operatorios dedicados.</p>
                    <ul class="ve-feat__list">
                        <li><Icon Name="check" Size="14" /> Monitoreo anestésico continuo</li>
                        <li><Icon Name="check" Size="14" /> Hospitalización 24/7</li>
                        <li><Icon Name="check" Size="14" /> Cirugía de tejidos blandos y ortopédica</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Servicios secundarios (grid compacto) -->
    <div class="ve-w">
        <div class="ve-svc-mini">
            <div class="ve-svc-mini__item reveal stagger-4">
                <div class="ve-svc-mini__icon"><Icon Name="pill" Size="22" /></div>
                <h4>Vacunación</h4>
                <p>Programas completos para cada etapa de vida.</p>
            </div>
            <div class="ve-svc-mini__item reveal stagger-5">
                <div class="ve-svc-mini__icon"><Icon Name="scissors" Size="22" /></div>
                <h4>Peluquería</h4>
                <p>Baños medicados y cortes profesionales.</p>
            </div>
            <div class="ve-svc-mini__item reveal stagger-6">
                <div class="ve-svc-mini__icon"><Icon Name="chart" Size="22" /></div>
                <h4>Imagenología</h4>
                <p>Ecografía, radiografía y electrocardiograma.</p>
            </div>
        </div>
    </div>
</section>

<!-- ▸ ESPECIALISTAS (showcase horizontal grande) -->
<section class="ve-section ve-section--soft" id="especialistas">
    <div class="ve-w">
        <div class="ve-sh">
            <span class="ve-tag">Equipo Médico</span>
            <h2>Nuestros Especialistas</h2>
        </div>

        <div class="ve-spec-list">
            <div class="ve-spec reveal stagger-1">
                <div class="ve-spec__photo">
                    <div class="ve-spec__avatar" style="display:flex"><Icon Name="brain" Size="32" /></div>
                </div>
                <div class="ve-spec__body">
                    <div class="ve-spec__header">
                        <h3>Dr. Hernán Vargas</h3>
                        <span class="ve-spec__badge">Neurología</span>
                    </div>
                    <p>Especialista en convulsiones, problemas de equilibrio, dolor de cuello y movimientos anormales. Más de 15 años de experiencia en neurología veterinaria.</p>
                    <div class="ve-spec__meta"><Icon Name="calendar" Size="14" /> Todos los Sábados</div>
                </div>
            </div>
            <div class="ve-spec reveal stagger-2">
                <div class="ve-spec__photo">
                    <div class="ve-spec__avatar ve-spec__avatar--coral" style="display:flex"><Icon Name="cat" Size="32" /></div>
                </div>
                <div class="ve-spec__body">
                    <div class="ve-spec__header">
                        <h3>Dra. Pilar Muñoz</h3>
                        <span class="ve-spec__badge ve-spec__badge--coral">Medicina Felina</span>
                    </div>
                    <p>Especialista exclusiva en gatos. Atención cuidadosa en un ambiente diseñado para felinos, reduciendo el estrés de cada visita.</p>
                    <div class="ve-spec__meta"><Icon Name="calendar" Size="14" /> Agenda Disponible</div>
                </div>
            </div>
            <div class="ve-spec reveal stagger-3">
                <div class="ve-spec__photo">
                    <div class="ve-spec__avatar ve-spec__avatar--purple" style="display:flex"><Icon Name="flask" Size="32" /></div>
                </div>
                <div class="ve-spec__body">
                    <div class="ve-spec__header">
                        <h3>Endocrinología</h3>
                        <span class="ve-spec__badge ve-spec__badge--purple">Visitante</span>
                    </div>
                    <p>Tratamiento de problemas hormonales, diabetes, tiroides y condiciones endocrinas en pequeños animales.</p>
                    <div class="ve-spec__meta"><Icon Name="calendar" Size="14" /> Consultar disponibilidad</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ CONÓCENOS (full-width visual) -->
<section class="ve-about-visual">
    <div class="ve-about-visual__bg">
        <img src="@ImagePaths.Clinic.Fachada" alt="San Pablo Vet Clínic"
             onerror="this.style.display='none'" />
    </div>
    <div class="ve-about-visual__overlay"></div>
    <div class="ve-about-visual__content reveal">
        <span class="ve-tag ve-tag--light">Desde 2014</span>
        <h2>Más que una clínica</h2>
        <p>
            En San Pablo Vet Clínic nos apasiona la medicina veterinaria. Un equipo multidisciplinario
            con especialistas certificados, tecnología de última generación y un compromiso
            genuino con cada paciente.
        </p>
        <div class="ve-about-visual__feats">
            <div class="ve-about-visual__feat"><Icon Name="alarm" Size="18" /> <span>Urgencias 24/7</span></div>
            <div class="ve-about-visual__feat"><Icon Name="brain" Size="18" /> <span>Especialistas</span></div>
            <div class="ve-about-visual__feat"><Icon Name="microscope" Size="18" /> <span>Lab IDEXX</span></div>
            <div class="ve-about-visual__feat"><Icon Name="van" Size="18" /> <span>Vet Móvil</span></div>
        </div>
        <a href="conocenos" class="ve-btn ve-btn--glass"><Icon Name="heart" Size="18" /> Conoce nuestra historia</a>
    </div>
</section>

<!-- ▸ VET MÓVIL (ancho completo, visual) -->
<section class="ve-section">
    <div class="ve-w">
        <div class="ve-movil reveal">
            <div class="ve-movil__img">
                <img src="@ImagePaths.Services.VetMovil" alt="Servicio veterinario a domicilio"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="ve-movil__fb"><Icon Name="van" Size="52" /><span>Servicio Móvil</span></div>
            </div>
            <div class="ve-movil__body">
                <span class="ve-tag">Atención a Domicilio</span>
                <h2>San Pablo Vet Móvil</h2>
                <p>
                    Llevamos la atención veterinaria profesional a la puerta de tu casa.
                    Ideal para mascotas que se estresan con los viajes o tutores con movilidad reducida.
                </p>
                <ul class="ve-check-list">
                    <li><Icon Name="check" Size="16" /> Consultas veterinarias completas</li>
                    <li><Icon Name="check" Size="16" /> Vacunación y toma de muestras</li>
                    <li><Icon Name="check" Size="16" /> Control de pacientes crónicos</li>
                    <li><Icon Name="check" Size="16" /> Lunes a Domingo, 09:00 a 16:30 hrs</li>
                </ul>
                <a href="@AppConstants.Urls.WhatsAppMobileVetLink" target="_blank" class="ve-btn ve-btn--coral">
                    <Icon Name="phone" Size="18" /> @AppConstants.Phone.MobileVetWhatsAppFormatted
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ▸ UBICACIÓN + CONTACTO -->
<section class="ve-section ve-section--soft" id="contacto">
    <div class="ve-w">
        <div class="ve-location reveal">
            <div class="ve-location__info">
                <span class="ve-tag">Encuéntranos</span>
                <h2>Ubicación</h2>
                <div class="ve-location__details">
                    <div class="ve-location__row"><Icon Name="location" Size="16" /> <span>@AppConstants.Clinic.FullAddress</span></div>
                    <div class="ve-location__row"><Icon Name="clock" Size="16" /> <span>Abierto 24 horas, todos los días</span></div>
                    <div class="ve-location__row"><Icon Name="phone" Size="16" /> <span>@AppConstants.Phone.AllPhonesFormatted</span></div>
                </div>
                <div class="ve-location__actions">
                    <a href="@AppConstants.Maps.DirectionsUrl" target="_blank" class="ve-btn ve-btn--dark"><Icon Name="location" Size="18" /> Google Maps</a>
                    <a href="contacto" class="ve-btn ve-btn--outline"><Icon Name="phone" Size="18" /> Contacto</a>
                </div>
                <div class="ve-location__social">
                    <a href="@AppConstants.Social.InstagramUrl" target="_blank">@@spvetclinic</a>
                    <a href="@AppConstants.Social.FacebookUrl" target="_blank">Facebook</a>
                </div>
            </div>
            <div class="ve-location__map">
                <div class="ve-location__map-fb" style="display:flex">
                    <Icon Name="location" Size="40" />
                    <span>Rancagua, Chile</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ▸ CTA FINAL -->
<section class="ve-cta">
    <div class="ve-cta__inner reveal">
        <span class="ve-tag ve-tag--light">Disponible 24/7</span>
        <h2>¿Tu mascota necesita<br />atención <em>ahora</em>?</h2>
        <div class="ve-cta__btns">
            <a href="contacto" class="ve-btn ve-btn--coral ve-btn--lg"><Icon Name="alarm" Size="20" /> Urgencias 24/7</a>
            <a href="@AppConstants.Clinic.BookingUrl" target="_blank" class="ve-btn ve-btn--glass ve-btn--lg"><Icon Name="calendar" Size="20" /> Agendar Consulta</a>
        </div>
        <div class="ve-cta__addr"><Icon Name="location" Size="14" /> @AppConstants.Clinic.FullAddress</div>
    </div>
</section>

<div class="ve-back">
    <NavLink href="variantes" class="ve-back__link">← Volver a las variantes</NavLink>
</div>

<style>
    /* ===== VARIANTE E — EDITORIAL VISUAL ===== */
    .ve-w { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }
    .ve-w-wide { max-width: 1280px; margin: 0 auto; padding: 0 2rem; }
    .ve-tag { display: inline-block; font-size: 0.7rem; font-weight: 700; color: var(--accent-coral); text-transform: uppercase; letter-spacing: 0.15em; }
    .ve-tag--light { color: rgba(255,255,255,0.5); }
    .ve-accent { background: linear-gradient(135deg, var(--primary-teal), #87d4e8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .ve-sh { margin-bottom: 2.5rem; }
    .ve-sh h2 { font-size: var(--font-size-h2); font-weight: 800; color: var(--text-dark); margin: 0.25rem 0 0; letter-spacing: -0.02em; }

    .ve-check-list { list-style: none; padding: 0; margin: 0 0 1.75rem; display: flex; flex-direction: column; gap: 0.5rem; }
    .ve-check-list li { display: flex; align-items: center; gap: 0.5rem; font-size: var(--font-size-sm); color: var(--text-dark); font-weight: 500; }

    /* BUTTONS */
    .ve-btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.875rem 1.75rem; border-radius: var(--border-radius);
        font-weight: 700; font-size: var(--font-size-base); text-decoration: none;
        transition: var(--transition); border: 2px solid transparent;
        text-transform: uppercase; letter-spacing: 0.04em;
    }
    .ve-btn--lg { padding: 1rem 2.25rem; font-size: 1.0625rem; }
    .ve-btn--coral { background: var(--accent-coral); color: white; border-color: var(--accent-coral); }
    .ve-btn--coral:hover { background: var(--accent-coral-dark); border-color: var(--accent-coral-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(187,84,95,0.4); }
    .ve-btn--glass { background: rgba(255,255,255,0.08); color: white; border-color: rgba(255,255,255,0.2); backdrop-filter: blur(8px); }
    .ve-btn--glass:hover { background: rgba(255,255,255,0.15); border-color: rgba(255,255,255,0.4); }
    .ve-btn--dark { background: var(--text-dark); color: white; border-color: var(--text-dark); }
    .ve-btn--dark:hover { background: #000; transform: translateY(-2px); box-shadow: var(--shadow-medium); }
    .ve-btn--outline { background: transparent; color: var(--text-dark); border-color: #d4d8dd; }
    .ve-btn--outline:hover { border-color: var(--primary-teal); color: var(--primary-teal); }

    /* HERO */
    .ve-hero {
        min-height: var(--hero-height, 100vh);
        position: relative; overflow: hidden; background: #0d0d0d;
    }
    .ve-hero__slide {
        position: absolute; inset: 0;
        display: flex; align-items: flex-end; justify-content: flex-start;
        padding: 6rem 4rem;
        opacity: 0; visibility: hidden; transition: opacity 0.8s ease, visibility 0.8s ease;
    }
    .ve-hero__slide.active { opacity: 1; visibility: visible; }
    .ve-hero__bg { position: absolute; inset: 0; }
    .ve-hero__bg img { width: 100%; height: 100%; object-fit: cover; opacity: 0.35; filter: grayscale(15%); }
    .ve-hero__overlay { position: absolute; inset: 0; background: linear-gradient(0deg, rgba(13,13,13,0.9) 0%, rgba(13,13,13,0.3) 50%, rgba(13,13,13,0.5) 100%); }
    .ve-hero__content { position: relative; z-index: 1; max-width: 700px; }
    .ve-hero__tag { display: inline-flex; align-items: center; gap: 8px; color: var(--accent-coral); font-size: var(--font-size-sm); font-weight: 700; letter-spacing: 0.15em; margin-bottom: 1.25rem; }
    .ve-pulse { width: 8px; height: 8px; border-radius: 50%; background: var(--accent-coral); animation: ve-pulse 1.5s ease-in-out infinite; }
    @@keyframes ve-pulse { 0%,100%{box-shadow:0 0 0 0 rgba(187,84,95,0.5)} 50%{box-shadow:0 0 0 8px rgba(187,84,95,0)} }
    .ve-hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; color: white; line-height: 1.05; margin: 0 0 1rem; letter-spacing: -0.04em; }
    .ve-hero p { color: rgba(255,255,255,0.55); font-size: 1.125rem; margin: 0 0 2rem; line-height: 1.6; }
    .ve-hero__btns { display: flex; gap: 1rem; flex-wrap: wrap; }

    .ve-hero__dots {
        position: absolute; bottom: 2rem; right: 4rem;
        display: flex; gap: 0.75rem; z-index: 10;
    }
    .ve-hero__dot {
        width: 10px; height: 10px; border-radius: 50%;
        background: rgba(255,255,255,0.3); border: none; padding: 0;
        cursor: pointer; transition: all 0.3s ease;
    }
    .ve-hero__dot.active { background: white; width: 28px; border-radius: 5px; }
    .ve-hero__dot:hover { background: rgba(255,255,255,0.6); }

    .ve-hero__nav {
        position: absolute; top: 50%; transform: translateY(-50%);
        width: 48px; height: 48px; border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.15); background: rgba(0,0,0,0.25);
        color: white; font-size: 1.5rem; cursor: pointer; z-index: 10;
        display: flex; align-items: center; justify-content: center;
        transition: all 0.3s ease; backdrop-filter: blur(4px);
    }
    .ve-hero__nav:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.3); }
    .ve-hero__nav--prev { left: 1.5rem; }
    .ve-hero__nav--next { right: 1.5rem; }

    /* URGENCY STRIP */
    .ve-urg-strip { background: var(--accent-coral); padding: 0.875rem 0; }
    .ve-urg-strip__inner {
        display: flex; align-items: center; justify-content: center;
        gap: 0.75rem; flex-wrap: wrap;
        color: white; font-size: var(--font-size-sm); font-weight: 500;
    }
    .ve-urg-strip__inner strong { font-weight: 800; letter-spacing: 0.04em; }
    .ve-urg-strip__sep { opacity: 0.5; }
    .ve-urg-strip__link {
        background: rgba(255,255,255,0.2); color: white; padding: 0.35rem 1rem;
        border-radius: 50px; text-decoration: none; font-weight: 700;
        font-size: 0.8rem; transition: var(--transition);
    }
    .ve-urg-strip__link:hover { background: rgba(255,255,255,0.3); }

    /* SECTIONS */
    .ve-section { padding: 5rem 0; background: white; }
    .ve-section--soft { background: #f9fafb; }

    /* FEATURED SERVICES (editorial) */
    .ve-feat { display: flex; flex-direction: column; gap: 1.5rem; margin-bottom: 3rem; }
    .ve-feat__card {
        display: grid; grid-template-columns: 1.2fr 1fr; gap: 0;
        border-radius: 16px; overflow: hidden; border: 1px solid #eef1f5;
        background: white; box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        transition: var(--transition);
    }
    .ve-feat__card:hover { box-shadow: 0 12px 40px rgba(0,0,0,0.08); }
    .ve-feat__card--rev { direction: rtl; }
