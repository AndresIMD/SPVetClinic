@code {
    private int currentSlide = 0;
    private const int TotalSlides = 3;
    private System.Threading.Timer? heroTimer;
    private bool heroPaused = false;

    protected override void OnInitialized()
    {
        heroTimer = new System.Threading.Timer(async _ =>
        {
            if (!heroPaused)
            {
                await InvokeAsync(() =>
                {
                    currentSlide = (currentSlide + 1) % TotalSlides;
                    StateHasChanged();
                });
            }
        }, null, TimeSpan.FromSeconds(6), TimeSpan.FromSeconds(6));
    }

    private void GoToSlide(int index) => currentSlide = index;
    private void NextSlide() => currentSlide = (currentSlide + 1) % TotalSlides;
    private void PrevSlide() => currentSlide = (currentSlide - 1 + TotalSlides) % TotalSlides;
    private void OnHeroEnter() => heroPaused = true;
    private void OnHeroLeave() => heroPaused = false;

    public void Dispose() => heroTimer?.Dispose();
}
